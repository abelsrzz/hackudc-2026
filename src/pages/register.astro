---
import Layout from "../layouts/Layout.astro";

import Footer from "../components/Footer.astro";

import patternSvg from "../assets/pattern.svg";
---

<Layout title="Registrarse">
  <main class="relative min-h-screen overflow-hidden">
    <!-- Tiled SVG pattern background -->
    <div
      class="absolute inset-0 pointer-events-none z-0 opacity-80"
      style={`background-image: url(${patternSvg.src}); background-repeat: repeat; background-size: 304px 304px;`}
    >
    </div>
    <div class="absolute inset-0 bg-[#0a0011]/80 pointer-events-none z-0"></div>
    <div
      class="absolute inset-0 pointer-events-none z-0"
      style="background: radial-gradient(ellipse at center, transparent 20%, rgba(0,0,0,0.6) 80%, rgba(0,0,0,0.97) 100%);"
    >
    </div>
    <div
      class="relative z-20 flex flex-col items-center justify-center min-h-screen pt-20 pb-10 px-4"
    >
      <h1
        class="text-4xl sm:text-5xl md:text-6xl font-black uppercase tracking-[0.2em] text-amber-300 drop-shadow-[0_4px_0_#7c3f00] mb-8 text-center"
      >
        Registrarse
      </h1>
      <p class="text-amber-100 text-lg mb-8 text-center">
        ¿Ya tienes una cuenta? <a
          href="/signin"
          class="text-amber-300 hover:text-amber-100 underline decoration-2 decoration-amber-300 underline-offset-4 transition-all"
          >Iniciar sesión</a
        >
      </p>

      <form
        action="/api/auth/register"
        method="post"
        class="w-full max-w-md space-y-5 bg-black/40 backdrop-blur-sm p-8 rounded-xl border border-amber-400/20 shadow-[0_0_20px_rgba(251,191,36,0.1)]"
      >
        <!-- Nombre -->
        <div class="space-y-2">
          <label
            for="name"
            class="block text-amber-200 font-bold tracking-wider uppercase text-sm"
            >Nombre completo <span class="text-red-400">*</span></label
          >
          <input
            type="text"
            name="name"
            id="name"
            placeholder="Tu nombre y apellidos"
            class="w-full px-4 py-3 bg-black/50 border-2 border-amber-400/40 rounded-lg text-amber-100 placeholder-amber-100/30 focus:outline-none focus:border-amber-300 focus:ring-1 focus:ring-amber-300 transition-all font-mono"
            required
          />
        </div>

        <!-- Correo -->
        <div class="space-y-2">
          <label
            for="email"
            class="block text-amber-200 font-bold tracking-wider uppercase text-sm"
            >Correo electrónico <span class="text-red-400">*</span></label
          >
          <input
            type="email"
            name="email"
            id="email"
            class="w-full px-4 py-3 bg-black/50 border-2 border-amber-400/40 rounded-lg text-amber-100 placeholder-amber-100/30 focus:outline-none focus:border-amber-300 focus:ring-1 focus:ring-amber-300 transition-all font-mono"
            required
          />
        </div>

        <!-- Contraseña -->
        <div class="space-y-2">
          <label
            for="password"
            class="block text-amber-200 font-bold tracking-wider uppercase text-sm"
            >Contraseña <span class="text-red-400">*</span></label
          >
          <input
            type="password"
            name="password"
            id="password"
            class="w-full px-4 py-3 bg-black/50 border-2 border-amber-400/40 rounded-lg text-amber-100 placeholder-amber-100/30 focus:outline-none focus:border-amber-300 focus:ring-1 focus:ring-amber-300 transition-all font-mono"
            required
            minlength="6"
          />
        </div>

        <div class="border-t border-amber-400/15 pt-4 space-y-5">
          <p
            class="text-amber-200/40 text-xs uppercase tracking-widest font-bold"
          >
            Datos académicos (opcionales)
          </p>

          <!-- Institución -->
          <div class="space-y-2">
            <label
              for="institution"
              class="block text-amber-200 font-bold tracking-wider uppercase text-sm"
              >Universidad / Institución</label
            >
            <input
              type="text"
              name="institution"
              id="institution"
              placeholder="Ej: Universidade da Coruña"
              class="w-full px-4 py-3 bg-black/50 border-2 border-amber-400/40 rounded-lg text-amber-100 placeholder-amber-100/30 focus:outline-none focus:border-amber-300 focus:ring-1 focus:ring-amber-300 transition-all font-mono"
            />
          </div>

          <!-- Grado / Carrera -->
          <div class="space-y-2">
            <label
              for="degree"
              class="block text-amber-200 font-bold tracking-wider uppercase text-sm"
              >Grado / Carrera</label
            >
            <input
              type="text"
              name="degree"
              id="degree"
              placeholder="Ej: Ing. Informática"
              class="w-full px-4 py-3 bg-black/50 border-2 border-amber-400/40 rounded-lg text-amber-100 placeholder-amber-100/30 focus:outline-none focus:border-amber-300 focus:ring-1 focus:ring-amber-300 transition-all font-mono"
            />
          </div>

          <!-- Año de estudio -->
          <div class="space-y-2">
            <label
              for="year_of_study"
              class="block text-amber-200 font-bold tracking-wider uppercase text-sm"
              >Año de estudio</label
            >
            <select
              name="year_of_study"
              id="year_of_study"
              class="w-full px-4 py-3 bg-black/50 border-2 border-amber-400/40 rounded-lg text-amber-100 focus:outline-none focus:border-amber-300 focus:ring-1 focus:ring-amber-300 transition-all appearance-none cursor-pointer"
            >
              <option value="" class="text-amber-100/30 bg-[#0a0011]"
                >Selecciona…</option
              >
              <option value="1" class="bg-[#0a0011]">1º año</option>
              <option value="2" class="bg-[#0a0011]">2º año</option>
              <option value="3" class="bg-[#0a0011]">3º año</option>
              <option value="4" class="bg-[#0a0011]">4º año</option>
              <option value="master" class="bg-[#0a0011]">Máster</option>
              <option value="phd" class="bg-[#0a0011]">Doctorado</option>
              <option value="other" class="bg-[#0a0011]">Otro</option>
            </select>
          </div>

          <!-- GitHub -->
          <div class="space-y-2">
            <label
              for="github"
              class="block text-amber-200 font-bold tracking-wider uppercase text-sm"
              >GitHub</label
            >
            <div class="relative">
              <span
                class="absolute left-4 top-1/2 -translate-y-1/2 text-amber-100/40 font-mono text-sm"
                >github.com/</span
              >
              <input
                type="text"
                name="github"
                id="github"
                placeholder="tu-usuario"
                class="w-full pl-[7.5rem] pr-4 py-3 bg-black/50 border-2 border-amber-400/40 rounded-lg text-amber-100 placeholder-amber-100/30 focus:outline-none focus:border-amber-300 focus:ring-1 focus:ring-amber-300 transition-all font-mono"
              />
            </div>
          </div>
        </div>

        <button
          type="submit"
          class="w-full mt-4 px-8 py-4 bg-amber-400 text-black font-black tracking-[0.2em] uppercase text-sm rounded-lg hover:bg-amber-300 transition-all duration-300 hover:shadow-[0_0_20px_rgba(251,191,36,0.4)] hover:scale-[1.02] active:scale-[0.98]"
        >
          Registrarse
        </button>
      </form>
      <Footer />
    </div>
  </main>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import DashboardCard from "../components/DashboardCard.astro";
import ShowSponsors from "../components/ShowSponsors.astro";
import ShowCollaborators from "../components/ShowCollaborators.astro";
import SignoutCard from "../components/SignoutCard.astro";
import patternSvg from "../assets/pattern.svg";
import { supabase } from "../lib/supabase";

const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) {
  return Astro.redirect("/signin");
}

let session;
try {
  session = await supabase.auth.setSession({
    refresh_token: refreshToken.value,
    access_token: accessToken.value,
  });
  if (session.error) {
    return Astro.redirect("/signin");
  }
} catch (error) {
  return Astro.redirect("/signin");
}

const user = session.data.user;

// Obtener rol del usuario
const { data: profile } = await supabase
  .from("profiles")
  .select("role")
  .eq("id", user?.id)
  .single();

const isAdmin = profile?.role?.toLowerCase() === "admin";
const isMentor = profile?.role?.toLowerCase() === "mentor";
---

<Layout title="Dashboard — HackUDC">
  <main class="relative min-h-screen overflow-hidden">
    <!-- Background layers -->
    <div
      class="absolute inset-0 pointer-events-none z-0 opacity-80"
      style={`background-image: url(${patternSvg.src}); background-repeat: repeat; background-size: 304px 304px;`}
    >
    </div>
    <div class="absolute inset-0 bg-[#0a0011]/80 pointer-events-none z-0"></div>
    <div
      class="absolute inset-0 pointer-events-none z-0"
      style="background: radial-gradient(ellipse at center, transparent 20%, rgba(0,0,0,0.6) 80%, rgba(0,0,0,0.97) 100%);"
    >
    </div>

    <!-- Contenido principal -->
    <div class="relative z-20 flex flex-col min-h-screen px-4 pb-10">
      <!-- Cabecera -->
      <header
        class="flex items-center justify-between w-full max-w-5xl mx-auto pt-8 pb-6"
      >
        <a
          href="/"
          class="text-amber-300 hover:text-white font-bold uppercase tracking-widest text-sm transition-colors"
        >
          ← Inicio
        </a>

        <div class="flex items-center gap-3">
          {
            isAdmin && (
              <a
                href="/admin"
                class="px-4 py-2 bg-amber-500/20 hover:bg-amber-500/30 border border-amber-400/50 text-amber-300 rounded-lg transition-all duration-300 font-bold uppercase text-xs tracking-wider shadow-[0_0_10px_rgba(251,191,36,0.15)] hover:shadow-[0_0_15px_rgba(251,191,36,0.35)]"
              >
                ⚙ Admin
              </a>
            )
          }
          <a
            href="/profile"
            class="flex items-center gap-2 px-4 py-2 bg-black/40 hover:bg-black/60 border border-amber-400/30 hover:border-amber-400/60 text-amber-200 rounded-lg transition-all duration-300 font-bold uppercase text-xs tracking-wider"
          >
            <span
              class="w-6 h-6 rounded-full bg-amber-400/20 border border-amber-400 flex items-center justify-center text-amber-300 text-xs font-black"
            >
              {user?.email?.charAt(0).toUpperCase()}
            </span>
            Mi Perfil
          </a>
        </div>
      </header>

      <!-- Título -->
      <div class="flex flex-col items-center text-center mt-4 mb-12">
        <h1
          class="text-4xl sm:text-5xl md:text-6xl font-black uppercase tracking-[0.2em] text-amber-300 drop-shadow-[0_4px_0_#7c3f00]"
        >
          Dashboard
        </h1>
        <p class="text-amber-100/60 mt-3 text-base tracking-wide">
          Bienvenido/a, <span class="text-amber-200 font-semibold"
            >{user?.email}</span
          >
        </p>
      </div>

      <!-- Grid de acciones -->
      <div
        class="w-full max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"
      >
        <DashboardCard
          href="/challenges"
          emoji="🏆"
          title="Challenges"
          description="Explora los retos disponibles y presenta tu solución."
          linkText="Ver retos"
        />

        <DashboardCard
          href="/schedule"
          emoji="📅"
          title="Horario"
          description="Consulta el programa y los eventos del hackathon."
          linkText="Ver horario"
        />

        <DashboardCard
          href="/needhelp"
          emoji="🧑‍💻"
          title="Solicitudes de ayuda"
          description="Encuentra mentores o sponsors que te ayuden durante el evento."
          linkText="Ver solicitudes de ayuda"
        />

        <DashboardCard
          href="/projects"
          emoji="🚀"
          title="Proyectos"
          description="Registra tu equipo y gestiona los miembros de tu proyecto."
          linkText="Ver proyectos"
        />

        <DashboardCard
          href="/chat"
          emoji="💬"
          title="Chat"
          description="Habla con el resto de participantes, mentores y sponsors."
          linkText="Abrir chat"
        />

        <DashboardCard
          href="/photos"
          emoji="📸"
          title="Fotos"
          description="El álbum compartido del hackathon. ¡Comparte el momento!"
          linkText="Ver fotos"
        />

        <DashboardCard
          href="/information"
          emoji="ℹ️"
          title="Información"
          description="Todo lo que necesitas saber sobre el hackathon."
          linkText="Ver info"
        />

        {
          (isMentor || isAdmin) && (
            <DashboardCard
              href="/needhelp"
              emoji="🙋"
              title="Need Help"
              description="Gestiona las solicitudes de ayuda de los equipos."
              linkText="Ver solicitudes"
              color="blue"
            />
          )
        }

        {
          (isMentor || isAdmin) && (
            <DashboardCard
              href="/tasks"
              emoji="📋"
              title="Tareas"
              description="Gestiona las tareas del equipo de mentores."
              linkText="Ver tareas"
              color="blue"
            />
          )
        }

        <SignoutCard />
      </div>
      <ShowSponsors />
      <ShowCollaborators />
      <Footer />
    </div>
  </main>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import patternSvg from "../assets/pattern.svg";
import { supabase } from "../lib/supabase";

const accessToken = Astro.cookies.get("sb-access-token");
const refreshToken = Astro.cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) {
  return Astro.redirect("/signin");
}

let session;
try {
  session = await supabase.auth.setSession({
    refresh_token: refreshToken.value,
    access_token: accessToken.value,
  });
  if (session.error) {
    return Astro.redirect("/signin");
  }
} catch (error) {
  return Astro.redirect("/signin");
}

const user = session.data.user;

// Obtener rol del usuario
const { data: profile } = await supabase
  .from("profiles")
  .select("role")
  .eq("id", user?.id)
  .single();

const isAdmin = profile?.role === "admin";
const isMentor = profile?.role === "mentor";
---

<Layout title="Dashboard — HackUDC">
  <main class="relative min-h-screen overflow-hidden">
    <!-- Background layers -->
    <div
      class="absolute inset-0 pointer-events-none z-0 opacity-80"
      style={`background-image: url(${patternSvg.src}); background-repeat: repeat; background-size: 304px 304px;`}
    >
    </div>
    <div class="absolute inset-0 bg-[#0a0011]/80 pointer-events-none z-0"></div>
    <div
      class="absolute inset-0 pointer-events-none z-0"
      style="background: radial-gradient(ellipse at center, transparent 20%, rgba(0,0,0,0.6) 80%, rgba(0,0,0,0.97) 100%);"
    >
    </div>

    <!-- Contenido principal -->
    <div class="relative z-20 flex flex-col min-h-screen px-4 pb-10">
      <!-- Cabecera -->
      <header
        class="flex items-center justify-between w-full max-w-5xl mx-auto pt-8 pb-6"
      >
        <a
          href="/"
          class="text-amber-300 hover:text-white font-bold uppercase tracking-widest text-sm transition-colors"
        >
          ← Inicio
        </a>

        <div class="flex items-center gap-3">
          {
            isAdmin && (
              <a
                href="/admin"
                class="px-4 py-2 bg-amber-500/20 hover:bg-amber-500/30 border border-amber-400/50 text-amber-300 rounded-lg transition-all duration-300 font-bold uppercase text-xs tracking-wider shadow-[0_0_10px_rgba(251,191,36,0.15)] hover:shadow-[0_0_15px_rgba(251,191,36,0.35)]"
              >
                ⚙ Admin
              </a>
            )
          }
          <a
            href="/profile"
            class="flex items-center gap-2 px-4 py-2 bg-black/40 hover:bg-black/60 border border-amber-400/30 hover:border-amber-400/60 text-amber-200 rounded-lg transition-all duration-300 font-bold uppercase text-xs tracking-wider"
          >
            <span
              class="w-6 h-6 rounded-full bg-amber-400/20 border border-amber-400 flex items-center justify-center text-amber-300 text-xs font-black"
            >
              {user?.email?.charAt(0).toUpperCase()}
            </span>
            Mi Perfil
          </a>
        </div>
      </header>

      <!-- Título -->
      <div class="flex flex-col items-center text-center mt-4 mb-12">
        <h1
          class="text-4xl sm:text-5xl md:text-6xl font-black uppercase tracking-[0.2em] text-amber-300 drop-shadow-[0_4px_0_#7c3f00]"
        >
          Dashboard
        </h1>
        <p class="text-amber-100/60 mt-3 text-base tracking-wide">
          Bienvenido/a, <span class="text-amber-200 font-semibold"
            >{user?.email}</span
          >
        </p>
      </div>

      <!-- Grid de acciones -->
      <div
        class="w-full max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"
      >
        <!-- Challenges -->
        <a
          href="/challenges"
          class="group flex flex-col gap-3 bg-black/40 backdrop-blur-sm p-6 rounded-xl border border-amber-400/20 hover:border-amber-400/50 shadow-[0_0_20px_rgba(251,191,36,0.05)] hover:shadow-[0_0_25px_rgba(251,191,36,0.2)] transition-all duration-300 hover:scale-[1.02]"
        >
          <div class="text-3xl">🏆</div>
          <h2
            class="text-amber-300 font-black uppercase tracking-widest text-sm group-hover:text-white transition-colors"
          >
            Challenges
          </h2>
          <p class="text-amber-100/50 text-sm leading-relaxed">
            Explora los retos disponibles y presenta tu solución.
          </p>
          <span
            class="mt-auto text-amber-400/60 text-xs font-bold uppercase tracking-widest group-hover:text-amber-300 transition-colors"
          >
            Ver retos →
          </span>
        </a>

        <!-- Horario -->
        <a
          href="/schedule"
          class="group flex flex-col gap-3 bg-black/40 backdrop-blur-sm p-6 rounded-xl border border-amber-400/20 hover:border-amber-400/50 shadow-[0_0_20px_rgba(251,191,36,0.05)] hover:shadow-[0_0_25px_rgba(251,191,36,0.2)] transition-all duration-300 hover:scale-[1.02]"
        >
          <div class="text-3xl">📅</div>
          <h2
            class="text-amber-300 font-black uppercase tracking-widest text-sm group-hover:text-white transition-colors"
          >
            Horario
          </h2>
          <p class="text-amber-100/50 text-sm leading-relaxed">
            Consulta el programa y los eventos del hackathon.
          </p>
          <span
            class="mt-auto text-amber-400/60 text-xs font-bold uppercase tracking-widest group-hover:text-amber-300 transition-colors"
          >
            Ver horario →
          </span>
        </a>

        <!-- Solicitudes de ayuda -->
        <a
          href="/needhelp"
          class="group flex flex-col gap-3 bg-black/40 backdrop-blur-sm p-6 rounded-xl border border-amber-400/20 hover:border-amber-400/50 shadow-[0_0_20px_rgba(251,191,36,0.05)] hover:shadow-[0_0_25px_rgba(251,191,36,0.2)] transition-all duration-300 hover:scale-[1.02]"
        >
          <div class="text-3xl">🧑‍💻</div>
          <h2
            class="text-amber-300 font-black uppercase tracking-widest text-sm group-hover:text-white transition-colors"
          >
            Solicitudes de ayuda
          </h2>
          <p class="text-amber-100/50 text-sm leading-relaxed">
            Encuentra mentores o sponsors que te ayuden durante el evento.
          </p>
          <span
            class="mt-auto text-amber-400/60 text-xs font-bold uppercase tracking-widest group-hover:text-amber-300 transition-colors"
          >
            Ver solicitudes de ayuda →
          </span>
        </a>

        <!-- Proyectos -->
        <a
          href="/projects"
          class="group flex flex-col gap-3 bg-black/40 backdrop-blur-sm p-6 rounded-xl border border-amber-400/20 hover:border-amber-400/50 shadow-[0_0_20px_rgba(251,191,36,0.05)] hover:shadow-[0_0_25px_rgba(251,191,36,0.2)] transition-all duration-300 hover:scale-[1.02]"
        >
          <div class="text-3xl">🚀</div>
          <h2
            class="text-amber-300 font-black uppercase tracking-widest text-sm group-hover:text-white transition-colors"
          >
            Proyectos
          </h2>
          <p class="text-amber-100/50 text-sm leading-relaxed">
            Registra tu equipo y gestiona los miembros de tu proyecto.
          </p>
          <span
            class="mt-auto text-amber-400/60 text-xs font-bold uppercase tracking-widest group-hover:text-amber-300 transition-colors"
          >
            Ver proyectos →
          </span>
        </a>

        {/* Need Help — solo para mentores y admins */}
        {
          (isMentor || isAdmin) && (
            <a
              href="/needhelp"
              class="group flex flex-col gap-3 bg-black/40 backdrop-blur-sm p-6 rounded-xl border border-blue-400/20 hover:border-blue-400/50 shadow-[0_0_20px_rgba(96,165,250,0.05)] hover:shadow-[0_0_25px_rgba(96,165,250,0.2)] transition-all duration-300 hover:scale-[1.02]"
            >
              <div class="text-3xl">🙋</div>
              <h2 class="text-blue-300 font-black uppercase tracking-widest text-sm group-hover:text-white transition-colors">
                Need Help
              </h2>
              <p class="text-amber-100/50 text-sm leading-relaxed">
                Gestiona las solicitudes de ayuda de los equipos.
              </p>
              <span class="mt-auto text-blue-400/60 text-xs font-bold uppercase tracking-widest group-hover:text-blue-300 transition-colors">
                Ver solicitudes →
              </span>
            </a>
          )
        }

        <!-- Fotos -->
        <a
          href="/photos"
          class="group flex flex-col gap-3 bg-black/40 backdrop-blur-sm p-6 rounded-xl border border-amber-400/20 hover:border-amber-400/50 shadow-[0_0_20px_rgba(251,191,36,0.05)] hover:shadow-[0_0_25px_rgba(251,191,36,0.2)] transition-all duration-300 hover:scale-[1.02]"
        >
          <div class="text-3xl">📸</div>
          <h2
            class="text-amber-300 font-black uppercase tracking-widest text-sm group-hover:text-white transition-colors"
          >
            Fotos
          </h2>
          <p class="text-amber-100/50 text-sm leading-relaxed">
            El álbum compartido del hackathon. ¡Comparte el momento!
          </p>
          <span
            class="mt-auto text-amber-400/60 text-xs font-bold uppercase tracking-widest group-hover:text-amber-300 transition-colors"
          >
            Ver fotos →
          </span>
        </a>

        <!-- Información -->
        <a
          href="/information"
          class="group flex flex-col gap-3 bg-black/40 backdrop-blur-sm p-6 rounded-xl border border-amber-400/20 hover:border-amber-400/50 shadow-[0_0_20px_rgba(251,191,36,0.05)] hover:shadow-[0_0_25px_rgba(251,191,36,0.2)] transition-all duration-300 hover:scale-[1.02]"
        >
          <div class="text-3xl">ℹ️</div>
          <h2
            class="text-amber-300 font-black uppercase tracking-widest text-sm group-hover:text-white transition-colors"
          >
            Información
          </h2>
          <p class="text-amber-100/50 text-sm leading-relaxed">
            Todo lo que necesitas saber sobre el hackathon.
          </p>
          <span
            class="mt-auto text-amber-400/60 text-xs font-bold uppercase tracking-widest group-hover:text-amber-300 transition-colors"
          >
            Ver info →
          </span>
        </a>

        <!-- Sponsors -->
        <a
          href="/sponsors"
          class="group flex flex-col gap-3 bg-black/40 backdrop-blur-sm p-6 rounded-xl border border-amber-400/20 hover:border-amber-400/50 shadow-[0_0_20px_rgba(251,191,36,0.05)] hover:shadow-[0_0_25px_rgba(251,191,36,0.2)] transition-all duration-300 hover:scale-[1.02]"
        >
          <div class="text-3xl">🤝</div>
          <h2
            class="text-amber-300 font-black uppercase tracking-widest text-sm group-hover:text-white transition-colors"
          >
            Patrocinadores
          </h2>
          <p class="text-amber-100/50 text-sm leading-relaxed">
            Conoce a las empresas que hacen posible HackUDC.
          </p>
          <span
            class="mt-auto text-amber-400/60 text-xs font-bold uppercase tracking-widest group-hover:text-amber-300 transition-colors"
          >
            Ver sponsors →
          </span>
        </a>

        <!-- Cerrar sesión -->
        <form
          action="/api/auth/signout"
          method="get"
          class="group flex flex-col gap-3 bg-black/40 backdrop-blur-sm p-6 rounded-xl border border-red-500/20 hover:border-red-500/50 shadow-[0_0_20px_rgba(220,38,38,0.05)] hover:shadow-[0_0_25px_rgba(220,38,38,0.2)] transition-all duration-300 hover:scale-[1.02] cursor-pointer"
        >
          <button type="submit" class="flex flex-col gap-3 text-left w-full">
            <div class="text-3xl">🚪</div>
            <h2
              class="text-red-400 font-black uppercase tracking-widest text-sm group-hover:text-red-300 transition-colors"
            >
              Cerrar Sesión
            </h2>
            <p class="text-amber-100/50 text-sm leading-relaxed">
              Finaliza tu sesión en HackUDC de forma segura.
            </p>
            <span
              class="mt-auto text-red-400/60 text-xs font-bold uppercase tracking-widest group-hover:text-red-300 transition-colors"
            >
              Salir →
            </span>
          </button>
        </form>
      </div>
    </div>

    <Footer />
  </main>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import patternSvg from "../assets/pattern.svg";
import { supabaseAdmin } from "../lib/supabase";

const { cookies, redirect, url } = Astro;

const accessToken = cookies.get("sb-access-token");
if (!accessToken) return redirect("/signin");

const {
  data: { user },
  error: userError,
} = await supabaseAdmin.auth.getUser(accessToken.value);
if (userError || !user) return redirect("/signin");

// Obtener perfil del usuario
const { data: profile, error: profileError } = await supabaseAdmin
  .from("profiles")
  .select("role, sponsor_id")
  .eq("id", user.id)
  .single();

if (profileError || !profile || !profile.sponsor_id) {
  return redirect("/challenges");
}

// Obtener datos actuales del sponsor
const { data: sponsor } = await supabaseAdmin
  .from("sponsors")
  .select("id, name, logo_path, website_url, description")
  .eq("id", profile.sponsor_id)
  .single();

const supabaseUrl = import.meta.env.SUPABASE_URL;

// Verificar si ya existe un challenge para este sponsor
const { data: existingChallenge } = await supabaseAdmin
  .from("challenges")
  .select("id")
  .eq("sponsor_id", profile.sponsor_id)
  .single();
---

<Layout title="Crear Challenge">
  {
    existingChallenge && (
      <>
        {/* Modal/Popup de challenge existente */}
        <div
          id="existing-challenge-modal"
          class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm"
        >
          <div class="bg-black/90 border-2 border-amber-400 rounded-xl p-8 max-w-md mx-4 shadow-[0_0_40px_rgba(251,191,36,0.3)]">
            <h2 class="text-2xl font-bold text-amber-300 uppercase tracking-wider mb-4 text-center">
              Challenge Existente
            </h2>
            <p class="text-amber-100 mb-6 text-center">
              Tu sponsor ya tiene un challenge creado. Solo puedes tener un
              challenge activo a la vez.
            </p>
            <div class="flex gap-4">
              <a
                href={`/challenge?id=${existingChallenge.id}`}
                class="flex-1 text-center px-6 py-3 bg-amber-400 text-black font-bold uppercase tracking-wider rounded-lg hover:bg-amber-300 hover:scale-[1.02] transition-all"
              >
                Ver Challenge
              </a>
              <a
                href="/challenges"
                class="flex-1 text-center px-6 py-3 border-2 border-amber-400/50 text-amber-200 font-bold uppercase tracking-wider rounded-lg hover:border-amber-400 hover:bg-amber-400/10 transition-all"
              >
                Volver
              </a>
            </div>
          </div>
        </div>
      </>
    )
  }

  <main class="relative min-h-screen overflow-hidden">
    <!-- Background layers -->
    <div
      class="absolute inset-0 pointer-events-none z-0 opacity-80"
      style={`background-image: url(${patternSvg.src}); background-repeat: repeat; background-size: 304px 304px;`}
    >
    </div>
    <div class="absolute inset-0 bg-[#0a0011]/80 pointer-events-none z-0"></div>
    <div
      class="absolute inset-0 pointer-events-none z-0"
      style="background: radial-gradient(ellipse at center, transparent 20%, rgba(0,0,0,0.6) 80%, rgba(0,0,0,0.97) 100%);"
    >
    </div>

    <div
      class="relative z-20 flex flex-col items-center min-h-screen pt-20 pb-10 px-4"
    >
      <!-- Botón de volver -->
      <div class="w-full max-w-4xl mb-6">
        <a
          href="/challenges"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-amber-200 px-6 py-3 font-bold uppercase tracking-[0.2em] text-amber-200 transition-all duration-300 hover:scale-105 hover:bg-amber-200 hover:text-black hover:shadow-[0_0_20px_rgba(251,191,36,0.3)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Volver
        </a>
      </div>

      <!-- Título -->
      <h1
        class="text-4xl sm:text-5xl md:text-6xl font-black uppercase tracking-[0.2em] text-amber-300 drop-shadow-[0_4px_0_#7c3f00] mb-12 text-center"
      >
        Crear Challenge
      </h1>

      <!-- Formulario -->
      <div
        class="w-full max-w-4xl bg-black/40 backdrop-blur-sm p-8 sm:p-12 rounded-xl border border-amber-400/20 shadow-[0_0_20px_rgba(251,191,36,0.1)]"
      >
        <!-- Información del Sponsor -->
        <div class="mb-8 pb-6 border-b border-amber-400/15">
          <h2
            class="text-xl font-bold uppercase tracking-wider text-amber-300 mb-4"
          >
            Información del Sponsor
          </h2>

          {/* Logo actual del sponsor */}
          {
            (() => {
              const logoUrl = sponsor?.logo_path
                ? `${supabaseUrl}/storage/v1/object/public/sponsor-logos/${sponsor.logo_path}`
                : null;
              return (
                <div class="mb-4">
                  <p class="text-amber-300/80 text-sm mb-2">Logo actual:</p>
                  {logoUrl ? (
                    <div class="flex items-center gap-4">
                      <img
                        src={logoUrl}
                        alt="Logo del sponsor"
                        class="w-24 h-24 object-cover rounded-xl bg-white/5 border border-amber-400/20"
                      />
                      <div>
                        <p class="text-amber-100/60 text-sm">{sponsor?.name}</p>
                      </div>
                    </div>
                  ) : (
                    <div class="flex items-center gap-4">
                      <div class="w-24 h-24 rounded-xl bg-amber-400/10 border border-amber-400/20 flex items-center justify-center text-amber-400/50 font-bold text-3xl">
                        {sponsor?.name?.charAt(0).toUpperCase()}
                      </div>
                      <p class="text-amber-100/40 text-sm">
                        No hay logo cargado aún
                      </p>
                    </div>
                  )}
                </div>
              );
            })()
          }

          {/* Upload de logo */}
          <div class="mb-4">
            <label
              for="logo-input"
              class="block text-amber-300 font-bold uppercase tracking-wider text-sm mb-2"
            >
              Subir/Actualizar Logo
            </label>
            <div class="flex items-center gap-3">
              <label
                for="logo-input"
                class="flex items-center gap-2 px-4 py-2 bg-black/50 border border-amber-400/30 rounded-lg cursor-pointer hover:border-amber-400/50 transition-all"
              >
                <span class="text-amber-200 text-sm">📁 Seleccionar imagen</span
                >
                <input
                  id="logo-input"
                  type="file"
                  accept="image/jpeg,image/png,image/webp,image/svg+xml"
                  class="hidden"
                />
              </label>
              <span id="logo-filename" class="text-amber-100/50 text-sm italic"
                >Ningún archivo seleccionado</span
              >
            </div>
            <p class="text-amber-200/50 text-xs mt-2">
              JPG, PNG, WebP, SVG · máx. 5 MB
            </p>
          </div>

          {/* Campos de información del sponsor */}
          <div class="space-y-4">
            <div>
              <label
                for="sponsor_name"
                class="block text-amber-300 font-bold uppercase tracking-wider text-sm mb-2"
              >
                Nombre de la Empresa *
              </label>
              <input
                type="text"
                id="sponsor_name"
                name="sponsor_name"
                required
                value={sponsor?.name ?? ""}
                class="w-full px-4 py-3 bg-black/50 border border-amber-400/30 rounded-lg text-amber-100 placeholder-amber-200/30 focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition-all"
                placeholder="Nombre de la empresa patrocinadora"
              />
            </div>

            <div>
              <label
                for="sponsor_website"
                class="block text-amber-300 font-bold uppercase tracking-wider text-sm mb-2"
              >
                Sitio Web
              </label>
              <input
                type="url"
                id="sponsor_website"
                name="sponsor_website"
                value={sponsor?.website_url ?? ""}
                class="w-full px-4 py-3 bg-black/50 border border-amber-400/30 rounded-lg text-amber-100 placeholder-amber-200/30 focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition-all"
                placeholder="https://ejemplo.com"
              />
            </div>

            <div>
              <label
                for="sponsor_description"
                class="block text-amber-300 font-bold uppercase tracking-wider text-sm mb-2"
              >
                Descripción de la Empresa
              </label>
              <textarea
                id="sponsor_description"
                name="sponsor_description"
                rows="3"
                class="w-full px-4 py-3 bg-black/50 border border-amber-400/30 rounded-lg text-amber-100 placeholder-amber-200/30 focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition-all resize-vertical"
                placeholder="Breve descripción de la empresa..."
                >{sponsor?.description ?? ""}</textarea
              >
            </div>
          </div>
        </div>

        <form
          method="post"
          action="/api/challenges/create"
          class="space-y-6"
          id="challenge-form"
        >
          <!-- Título -->
          <div>
            <label
              for="title"
              class="block text-amber-300 font-bold uppercase tracking-wider text-sm mb-2"
            >
              Título *
            </label>
            <input
              type="text"
              id="title"
              name="title"
              required
              class="w-full px-4 py-3 bg-black/50 border border-amber-400/30 rounded-lg text-amber-100 placeholder-amber-200/30 focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition-all"
              placeholder="Nombre del challenge"
            />
          </div>

          <!-- Descripción corta -->
          <div>
            <label
              for="short_description"
              class="block text-amber-300 font-bold uppercase tracking-wider text-sm mb-2"
            >
              Descripción Corta *
            </label>
            <input
              type="text"
              id="short_description"
              name="short_description"
              required
              class="w-full px-4 py-3 bg-black/50 border border-amber-400/30 rounded-lg text-amber-100 placeholder-amber-200/30 focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition-all"
              placeholder="Resumen breve del challenge"
            />
          </div>

          <!-- Contenido completo (Markdown) -->
          <div>
            <label
              for="content_markdown"
              class="block text-amber-300 font-bold uppercase tracking-wider text-sm mb-2"
            >
              Contenido Completo (Markdown) *
            </label>
            <textarea
              id="content_markdown"
              name="content_markdown"
              required
              rows="12"
              class="w-full px-4 py-3 bg-black/50 border border-amber-400/30 rounded-lg text-amber-100 placeholder-amber-200/30 focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition-all resize-vertical font-mono text-sm"
              placeholder="Descripción detallada del challenge en formato Markdown..."
            ></textarea>
            <p class="text-amber-200/50 text-xs mt-2">
              Puedes usar Markdown: **negrita**, *cursiva*, # títulos, listas,
              etc.
            </p>
          </div>

          <!-- Recompensa -->
          <div>
            <label
              for="reward"
              class="block text-amber-300 font-bold uppercase tracking-wider text-sm mb-2"
            >
              Recompensa
            </label>
            <input
              type="text"
              id="reward"
              name="reward"
              class="w-full px-4 py-3 bg-black/50 border border-amber-400/30 rounded-lg text-amber-100 placeholder-amber-200/30 focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition-all"
              placeholder="Ej: 500€, Hardware, Servicios..."
            />
          </div>

          <!-- Botones -->
          <div class="flex gap-4 pt-4">
            <button
              type="submit"
              class="flex-1 px-8 py-4 bg-amber-400 text-black font-bold uppercase tracking-[0.2em] rounded-lg hover:bg-amber-300 hover:scale-[1.02] hover:shadow-[0_0_30px_rgba(251,191,36,0.4)] transition-all duration-300"
            >
              Crear Challenge
            </button>
            <a
              href="/challenges"
              class="px-8 py-4 border-2 border-amber-400/50 text-amber-200 font-bold uppercase tracking-[0.2em] rounded-lg hover:border-amber-400 hover:bg-amber-400/10 transition-all duration-300 text-center"
            >
              Cancelar
            </a>
          </div>
        </form>
      </div>

      <div class="mt-10 w-full">
        <Footer />
      </div>
    </div>
  </main>
</Layout>

<script>
  // Mostrar nombre del archivo seleccionado
  const logoInput = document.getElementById("logo-input") as HTMLInputElement;
  const logoFilename = document.getElementById("logo-filename");

  logoInput?.addEventListener("change", () => {
    if (logoInput.files && logoInput.files[0]) {
      if (logoFilename) {
        logoFilename.textContent = logoInput.files[0].name;
      }
    } else {
      if (logoFilename) {
        logoFilename.textContent = "Ningún archivo seleccionado";
      }
    }
  });

  // Manejar el envío del formulario
  const form = document.getElementById("challenge-form") as HTMLFormElement;
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Primero, actualizar datos del sponsor si han cambiado
    const sponsorName = (
      document.getElementById("sponsor_name") as HTMLInputElement
    )?.value;
    const sponsorWebsite = (
      document.getElementById("sponsor_website") as HTMLInputElement
    )?.value;
    const sponsorDescription = (
      document.getElementById("sponsor_description") as HTMLTextAreaElement
    )?.value;

    // Si hay logo seleccionado, subirlo primero
    if (logoInput.files && logoInput.files[0]) {
      const logoFormData = new FormData();
      logoFormData.append("logo", logoInput.files[0]);

      try {
        const logoResponse = await fetch("/api/sponsors/upload-logo", {
          method: "POST",
          body: logoFormData,
        });

        if (!logoResponse.ok) {
          const errorData = await logoResponse.json();
          alert(
            "Error al subir el logo: " +
              (errorData.error || "Error desconocido"),
          );
          return;
        }
      } catch (error) {
        alert("Error al subir el logo: " + error);
        return;
      }
    }

    // Actualizar información del sponsor si es necesario
    if (sponsorName || sponsorWebsite || sponsorDescription) {
      try {
        const sponsorFormData = new FormData();
        if (sponsorName) sponsorFormData.append("name", sponsorName);
        if (sponsorWebsite)
          sponsorFormData.append("website_url", sponsorWebsite);
        if (sponsorDescription)
          sponsorFormData.append("description", sponsorDescription);

        const sponsorResponse = await fetch("/api/sponsors/update", {
          method: "POST",
          body: sponsorFormData,
        });

        if (!sponsorResponse.ok) {
          const errorData = await sponsorResponse.json();
          alert(
            "Error al actualizar datos del sponsor: " +
              (errorData.error || "Error desconocido"),
          );
          return;
        }
      } catch (error) {
        alert("Error al actualizar datos del sponsor: " + error);
        return;
      }
    }

    // Finalmente, enviar el formulario del challenge
    form.submit();
  });
</script>

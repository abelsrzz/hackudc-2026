---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import patternSvg from "../assets/pattern.svg";
import { supabaseAdmin } from "../lib/supabase";
import { FontAwesomeIcon } from "@fortawesome/react-fontawesome";
import {
  faGithub,
  faLinkedin,
  faTwitter,
  faInstagram,
} from "@fortawesome/free-brands-svg-icons";
import { faGlobe } from "@fortawesome/free-solid-svg-icons";

const accessToken = Astro.cookies.get("sb-access-token");
if (!accessToken) return Astro.redirect("/signin");

const {
  data: { user },
  error: userError,
} = await supabaseAdmin.auth.getUser(accessToken.value);
if (userError || !user) return Astro.redirect("/signin");

// Perfil completo
const { data: profile } = await supabaseAdmin
  .from("profiles")
  .select(
    "id, name, role, linkedin, github, twitter, website, instagram, institution, degree, year_of_study, avatar_url",
  )
  .eq("id", user.id)
  .single();

const isAdmin = profile?.role?.toLowerCase() === "admin";

// Proyecto del usuario (como miembro)
const { data: membership } = await supabaseAdmin
  .from("project_member")
  .select(
    `
    project_id,
    projects (
      id,
      name,
      created_at,
      sede,
      challenge_id,
      challenges (
        id,
        title,
        short_description,
        reward
      ),
      project_member (
        id,
        member_id,
        profiles (
          id,
          name,
          avatar_url
        )
      )
    )
  `,
  )
  .eq("member_id", user.id)
  .maybeSingle();

const project = (membership?.projects as any) ?? null;

const createdAt = new Date(user.created_at || "").toLocaleDateString("es-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const successMsg = Astro.url.searchParams.get("success");
const errorMsg = Astro.url.searchParams.get("error");

const YEARS = ["1º", "2º", "3º", "4º", "Máster 1º", "Máster 2º", "Doctorado"];
---

<Layout title="Mi Perfil — HackUDC">
  <main class="relative min-h-screen overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none z-0 opacity-80"
      style={`background-image: url(${patternSvg.src}); background-repeat: repeat; background-size: 304px 304px;`}
    >
    </div>
    <div class="absolute inset-0 bg-[#0a0011]/80 pointer-events-none z-0"></div>
    <div
      class="absolute inset-0 pointer-events-none z-0"
      style="background: radial-gradient(ellipse at center, transparent 20%, rgba(0,0,0,0.6) 80%, rgba(0,0,0,0.97) 100%);"
    >
    </div>

    <div
      class="relative z-20 flex flex-col items-center min-h-screen pt-10 pb-16 px-4"
    >
      <!-- Cabecera -->
      <div class="w-full max-w-3xl flex items-center justify-between mb-10">
        <a
          href="/dashboard"
          class="text-amber-300 hover:text-white font-bold uppercase tracking-widest text-sm transition-colors"
        >
          ← Dashboard
        </a>
        {
          isAdmin && (
            <a
              href="/admin"
              class="px-4 py-2 bg-amber-500/20 hover:bg-amber-500/30 border border-amber-400/50 text-amber-300 rounded-lg transition-all font-bold uppercase text-xs tracking-wider"
            >
              ⚙ Admin
            </a>
          )
        }
      </div>

      <!-- Avatar + título -->
      <div class="flex flex-col items-center mb-8">
        <!-- Foto de perfil con botón de subida -->
        <form
          id="avatar-form"
          action="/api/profile/upload-avatar"
          method="post"
          enctype="multipart/form-data"
          class="mb-3"
        >
          <label
            for="avatar-input"
            class="relative w-20 h-20 rounded-full cursor-pointer group block"
            title="Cambiar foto de perfil"
          >
            {
              profile?.avatar_url ? (
                <img
                  src={profile.avatar_url}
                  alt={profile?.name ?? "Avatar"}
                  class="w-20 h-20 rounded-full border-2 border-amber-400 object-cover shadow-[0_0_20px_rgba(251,191,36,0.3)]"
                />
              ) : (
                <div class="w-20 h-20 rounded-full bg-black border-2 border-amber-400 flex items-center justify-center text-amber-300 text-3xl font-black shadow-[0_0_20px_rgba(251,191,36,0.3)]">
                  {user.email?.charAt(0).toUpperCase()}
                </div>
              )
            }
            <div
              class="absolute inset-0 rounded-full bg-black/65 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none"
            >
              <span class="text-lg leading-none">📷</span>
              <span
                class="text-amber-300 text-[10px] font-bold uppercase tracking-widest mt-0.5"
                >Cambiar</span
              >
            </div>
          </label>
          <input
            id="avatar-input"
            type="file"
            name="avatar"
            accept="image/jpeg,image/png,image/webp"
            class="hidden"
          />
        </form>
        <h1
          class="text-3xl sm:text-4xl font-black uppercase tracking-[0.15em] text-amber-300 drop-shadow-[0_4px_0_#7c3f00]"
        >
          {profile?.name ?? user.email?.split("@")[0]}
        </h1>
        <p class="text-amber-100/40 text-sm mt-1">{user.email}</p>
        <span
          class="mt-2 px-3 py-0.5 rounded-full border border-amber-400/30 bg-amber-400/10 text-amber-300 text-xs font-bold uppercase tracking-widest"
        >
          {profile?.role ?? "Hacker"}
        </span>

        <!-- Redes sociales visibles (solo si hay datos) -->
        {
          (profile?.github ||
            profile?.linkedin ||
            profile?.twitter ||
            profile?.instagram ||
            profile?.website) && (
            <div class="flex flex-wrap gap-2 mt-3 justify-center">
              {profile?.github && (
                <a
                  href={
                    profile.github.startsWith("http")
                      ? profile.github
                      : `https://github.com/${profile.github}`
                  }
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 px-3 py-1 bg-black/40 border border-amber-400/20 hover:border-amber-400/50 rounded-full text-amber-200/60 hover:text-amber-200 text-xs font-mono transition-all"
                >
                  <FontAwesomeIcon icon={faGithub} className="h-4" />
                  {profile.github.replace(
                    /https?:\/\/(www\.)?github\.com\/?/,
                    "",
                  )}
                </a>
              )}
              {profile?.linkedin && (
                <a
                  href={
                    profile.linkedin.startsWith("http")
                      ? profile.linkedin
                      : `https://linkedin.com/in/${profile.linkedin}`
                  }
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 px-3 py-1 bg-black/40 border border-amber-400/20 hover:border-amber-400/50 rounded-full text-amber-200/60 hover:text-amber-200 text-xs font-mono transition-all"
                >
                  <FontAwesomeIcon icon={faLinkedin} className="h-4" />
                  {profile.linkedin.replace(
                    /https?:\/\/(www\.)?linkedin\.com\/in\/?/,
                    "",
                  )}
                </a>
              )}
              {profile?.twitter && (
                <a
                  href={
                    profile.twitter.startsWith("http")
                      ? profile.twitter
                      : `https://twitter.com/${profile.twitter}`
                  }
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 px-3 py-1 bg-black/40 border border-amber-400/20 hover:border-amber-400/50 rounded-full text-amber-200/60 hover:text-amber-200 text-xs font-mono transition-all"
                >
                  <FontAwesomeIcon icon={faTwitter} className="h-4" />
                  {profile.twitter
                    .replace(/https?:\/\/(www\.)?twitter\.com\/?/, "")
                    .replace(/https?:\/\/(www\.)?x\.com\/?/, "")}
                </a>
              )}
              {profile?.instagram && (
                <a
                  href={
                    profile.instagram.startsWith("http")
                      ? profile.instagram
                      : `https://instagram.com/${profile.instagram}`
                  }
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 px-3 py-1 bg-black/40 border border-amber-400/20 hover:border-amber-400/50 rounded-full text-amber-200/60 hover:text-amber-200 text-xs font-mono transition-all"
                >
                  <FontAwesomeIcon icon={faInstagram} className="h-4" />
                  {profile.instagram.replace(
                    /https?:\/\/(www\.)?instagram\.com\//,
                    "",
                  )}
                </a>
              )}
              {profile?.website && (
                <a
                  href={
                    profile.website.startsWith("http")
                      ? profile.website
                      : `https://${profile.website}`
                  }
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 px-3 py-1 bg-black/40 border border-amber-400/20 hover:border-amber-400/50 rounded-full text-amber-200/60 hover:text-amber-200 text-xs font-mono transition-all"
                >
                  <FontAwesomeIcon icon={faGlobe} className="h-4" />
                  {profile.website.replace(/https?:\/\/(www\.)?/, "")}
                </a>
              )}
            </div>
          )
        }

        <!-- Estudios visibles -->
        {
          (profile?.institution || profile?.degree) && (
            <p class="text-amber-100/40 text-xs mt-2 text-center">
              {[profile?.degree, profile?.year_of_study, profile?.institution]
                .filter(Boolean)
                .join(" · ")}
            </p>
          )
        }
      </div>

      <!-- Alertas -->
      {
        successMsg && (
          <div class="w-full max-w-3xl mb-6 px-4 py-3 bg-green-900/40 border border-green-400/40 text-green-300 rounded-lg text-sm font-bold text-center">
            ✓ Perfil actualizado correctamente.
          </div>
        )
      }
      {
        errorMsg && (
          <div class="w-full max-w-3xl mb-6 px-4 py-3 bg-red-900/40 border border-red-400/40 text-red-300 rounded-lg text-sm font-bold text-center">
            ✗ Error al guardar el perfil. Inténtalo de nuevo.
          </div>
        )
      }

      <div class="w-full max-w-3xl space-y-6">
        <!-- ── Formulario de perfil ── -->
        <section
          class="bg-black/50 backdrop-blur-sm rounded-xl border border-amber-400/25 overflow-hidden"
        >
          <div class="px-6 py-4 border-b border-amber-400/15">
            <h2
              class="text-amber-300 font-black uppercase tracking-widest text-xs"
            >
              Editar perfil
            </h2>
          </div>
          <form
            action="/api/profile/update"
            method="post"
            class="px-6 py-5 space-y-5"
          >
            <!-- Nombre -->
            <div>
              <label
                class="block text-amber-200/50 font-bold tracking-widest uppercase text-xs mb-1.5"
                >Nombre</label
              >
              <input
                type="text"
                name="name"
                value={profile?.name ?? ""}
                placeholder="Tu nombre completo"
                class="w-full px-4 py-3 bg-black/50 border border-amber-400/25 rounded-lg text-amber-100 placeholder-amber-100/25 focus:outline-none focus:border-amber-300 focus:ring-1 focus:ring-amber-300 transition-all text-sm font-mono"
              />
            </div>

            <!-- Redes sociales -->
            <div>
              <p
                class="text-amber-200/50 font-bold tracking-widest uppercase text-xs mb-3"
              >
                Redes sociales
              </p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <div class="flex items-center gap-2">
                  <span class="w-6 text-center shrink-0 text-amber-400/60">
                    <FontAwesomeIcon icon={faGithub} className="h-5" />
                  </span>
                  <div class="flex-1">
                    <label class="block text-amber-200/35 text-xs mb-1"
                      >GitHub</label
                    >
                    <input
                      type="text"
                      name="github"
                      value={profile?.github ?? ""}
                      placeholder="usuario o URL"
                      class="w-full px-3 py-2 bg-black/40 border border-amber-400/20 rounded-lg text-amber-100 placeholder-amber-100/20 focus:outline-none focus:border-amber-400/50 transition-all text-sm font-mono"
                    />
                  </div>
                </div>

                <div class="flex items-center gap-2">
                  <span class="w-6 text-center shrink-0 text-amber-400/60">
                    <FontAwesomeIcon icon={faLinkedin} className="h-5" />
                  </span>
                  <div class="flex-1">
                    <label class="block text-amber-200/35 text-xs mb-1"
                      >LinkedIn</label
                    >
                    <input
                      type="text"
                      name="linkedin"
                      value={profile?.linkedin ?? ""}
                      placeholder="usuario o URL"
                      class="w-full px-3 py-2 bg-black/40 border border-amber-400/20 rounded-lg text-amber-100 placeholder-amber-100/20 focus:outline-none focus:border-amber-400/50 transition-all text-sm font-mono"
                    />
                  </div>
                </div>

                <div class="flex items-center gap-2">
                  <span class="w-6 text-center shrink-0 text-amber-400/60">
                    <FontAwesomeIcon icon={faTwitter} className="h-5" />
                  </span>
                  <div class="flex-1">
                    <label class="block text-amber-200/35 text-xs mb-1"
                      >Twitter / X</label
                    >
                    <input
                      type="text"
                      name="twitter"
                      value={profile?.twitter ?? ""}
                      placeholder="usuario o URL"
                      class="w-full px-3 py-2 bg-black/40 border border-amber-400/20 rounded-lg text-amber-100 placeholder-amber-100/20 focus:outline-none focus:border-amber-400/50 transition-all text-sm font-mono"
                    />
                  </div>
                </div>

                <div class="flex items-center gap-2">
                  <span class="w-6 text-center shrink-0 text-amber-400/60">
                    <FontAwesomeIcon icon={faInstagram} className="h-5" />
                  </span>
                  <div class="flex-1">
                    <label class="block text-amber-200/35 text-xs mb-1"
                      >Instagram</label
                    >
                    <input
                      type="text"
                      name="instagram"
                      value={profile?.instagram ?? ""}
                      placeholder="usuario o URL"
                      class="w-full px-3 py-2 bg-black/40 border border-amber-400/20 rounded-lg text-amber-100 placeholder-amber-100/20 focus:outline-none focus:border-amber-400/50 transition-all text-sm font-mono"
                    />
                  </div>
                </div>

                <div class="flex items-center gap-2">
                  <span class="w-6 text-center shrink-0 text-amber-400/60">
                    <FontAwesomeIcon icon={faGlobe} className="h-5" />
                  </span>
                  <div class="flex-1">
                    <label class="block text-amber-200/35 text-xs mb-1"
                      >Web personal</label
                    >
                    <input
                      type="text"
                      name="website"
                      value={profile?.website ?? ""}
                      placeholder="https://…"
                      class="w-full px-3 py-2 bg-black/40 border border-amber-400/20 rounded-lg text-amber-100 placeholder-amber-100/20 focus:outline-none focus:border-amber-400/50 transition-all text-sm font-mono"
                    />
                  </div>
                </div>
              </div>
            </div>

            <!-- Estudios -->
            <div>
              <p
                class="text-amber-200/50 font-bold tracking-widest uppercase text-xs mb-3"
              >
                Estudios
              </p>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                <div class="sm:col-span-2">
                  <label class="block text-amber-200/35 text-xs mb-1"
                    >Centro / Universidad</label
                  >
                  <input
                    type="text"
                    name="institution"
                    value={profile?.institution ?? ""}
                    placeholder="p.ej. Universidade da Coruña"
                    class="w-full px-3 py-2 bg-black/40 border border-amber-400/20 rounded-lg text-amber-100 placeholder-amber-100/20 focus:outline-none focus:border-amber-400/50 transition-all text-sm font-mono"
                  />
                </div>

                <div>
                  <label class="block text-amber-200/35 text-xs mb-1"
                    >Curso</label
                  >
                  <select
                    name="year_of_study"
                    class="w-full px-3 py-2 bg-black/50 border border-amber-400/20 rounded-lg text-amber-100 focus:outline-none focus:border-amber-400/50 transition-all text-sm appearance-none cursor-pointer"
                  >
                    <option value="" class="bg-[#0a0011]">— curso —</option>
                    {
                      YEARS.map((y) => (
                        <option
                          value={y}
                          selected={profile?.year_of_study === y}
                          class="bg-[#0a0011]"
                        >
                          {y}
                        </option>
                      ))
                    }
                  </select>
                </div>

                <div class="sm:col-span-3">
                  <label class="block text-amber-200/35 text-xs mb-1"
                    >¿Qué estudias?</label
                  >
                  <input
                    type="text"
                    name="degree"
                    value={profile?.degree ?? ""}
                    placeholder="p.ej. Ingeniería Informática"
                    class="w-full px-3 py-2 bg-black/40 border border-amber-400/20 rounded-lg text-amber-100 placeholder-amber-100/20 focus:outline-none focus:border-amber-400/50 transition-all text-sm font-mono"
                  />
                </div>
              </div>
            </div>

            <div class="flex justify-end pt-2">
              <button
                type="submit"
                class="px-8 py-2.5 bg-amber-400 text-black font-black tracking-[0.15em] uppercase text-xs rounded-lg hover:bg-amber-300 transition-all duration-300 hover:shadow-[0_0_15px_rgba(251,191,36,0.4)] hover:scale-[1.02] active:scale-[0.98]"
              >
                Guardar cambios
              </button>
            </div>
          </form>
        </section>

        <!-- ── Info de cuenta (solo lectura) ── -->
        <section
          class="bg-black/50 backdrop-blur-sm rounded-xl border border-amber-400/15"
        >
          <div class="px-6 py-4 border-b border-amber-400/10">
            <h2
              class="text-amber-200/40 font-black uppercase tracking-widest text-xs"
            >
              Información de cuenta
            </h2>
          </div>
          <div class="px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                class="block text-amber-200/35 font-bold tracking-wider uppercase text-xs mb-1"
                >Correo</label
              >
              <div
                class="px-4 py-3 bg-black/40 border border-amber-400/15 rounded-lg text-amber-100/70 font-mono text-sm truncate"
              >
                {user.email}
              </div>
            </div>
            <div>
              <label
                class="block text-amber-200/35 font-bold tracking-wider uppercase text-xs mb-1"
                >Miembro desde</label
              >
              <div
                class="px-4 py-3 bg-black/40 border border-amber-400/15 rounded-lg text-amber-100/70 font-mono text-sm"
              >
                {createdAt}
              </div>
            </div>
          </div>
        </section>

        <!-- ── Mi proyecto ── -->
        {
          project ? (
            <section class="bg-black/50 backdrop-blur-sm rounded-xl border border-amber-400/25 overflow-hidden">
              <div class="px-6 py-4 border-b border-amber-400/15 flex items-center justify-between">
                <h2 class="text-amber-300 font-black uppercase tracking-widest text-xs">
                  🚀 Mi proyecto
                </h2>
                <a
                  href="/projects"
                  class="text-amber-400/50 hover:text-amber-300 text-xs uppercase tracking-widest font-bold transition-colors"
                >
                  Ver todos →
                </a>
              </div>
              <div class="px-6 py-5 space-y-4">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <h3 class="text-amber-200 font-black text-xl uppercase tracking-wide">
                    {project.name}
                  </h3>
                  {project.sede && (
                    <span class="px-3 py-1 bg-amber-400/10 border border-amber-400/25 rounded-full text-amber-300 text-xs font-bold uppercase tracking-widest">
                      📍 {project.sede}
                    </span>
                  )}
                </div>

                {project.challenges ? (
                  <div class="p-4 bg-black/40 rounded-lg border border-amber-400/15 space-y-1">
                    <p class="text-amber-200/40 text-xs uppercase tracking-widest font-bold">
                      Challenge
                    </p>
                    <p class="text-amber-200 font-bold text-sm">
                      {(project.challenges as any).title}
                    </p>
                    {(project.challenges as any).short_description && (
                      <p class="text-amber-100/50 text-xs leading-relaxed">
                        {(project.challenges as any).short_description}
                      </p>
                    )}
                    {(project.challenges as any).reward && (
                      <p class="text-amber-300 text-xs font-bold mt-1">
                        🏆 Premio: {(project.challenges as any).reward}
                      </p>
                    )}
                  </div>
                ) : (
                  <p class="text-amber-100/30 text-sm italic">
                    Sin challenge vinculado.
                  </p>
                )}

                <div>
                  <p class="text-amber-200/40 text-xs uppercase tracking-widest font-bold mb-2">
                    Equipo ({(project.project_member as any[])?.length ?? 0}{" "}
                    miembro
                    {(project.project_member as any[])?.length !== 1 ? "s" : ""}
                    )
                  </p>
                  <div class="flex flex-wrap gap-2">
                    {(project.project_member as any[])?.map((m: any) => (
                      <a
                        href={
                          m.member_id === user.id
                            ? "/profile"
                            : `/user/${m.profiles?.id ?? m.member_id}`
                        }
                        class={`flex items-center gap-2 px-3 py-1.5 rounded-full border text-xs font-bold transition-all hover:scale-[1.03] ${
                          m.member_id === user.id
                            ? "bg-amber-400/20 border-amber-400/50 text-amber-200"
                            : "bg-black/40 border-amber-400/15 text-amber-100/50 hover:border-amber-400/35 hover:text-amber-200"
                        }`}
                      >
                        {m.profiles?.avatar_url ? (
                          <img
                            src={m.profiles.avatar_url}
                            alt=""
                            class="w-5 h-5 rounded-full border border-amber-400/40 object-cover shrink-0"
                          />
                        ) : (
                          <span class="w-5 h-5 rounded-full bg-amber-400/20 border border-amber-400/40 flex items-center justify-center text-amber-300 text-xs font-black shrink-0">
                            {(m.profiles?.name ?? "?").charAt(0).toUpperCase()}
                          </span>
                        )}
                        {m.profiles?.name ?? "Sin nombre"}
                        {m.member_id === user.id && (
                          <span class="text-amber-400/60 text-[10px]">
                            (tú)
                          </span>
                        )}
                      </a>
                    ))}
                  </div>
                </div>

                <p class="text-amber-100/25 text-xs">
                  Creado el{" "}
                  {new Date(project.created_at).toLocaleDateString("es-ES", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </p>
              </div>
            </section>
          ) : (
            <section class="bg-black/40 backdrop-blur-sm rounded-xl border border-amber-400/10 px-6 py-8 text-center">
              <p class="text-amber-100/30 text-sm italic mb-3">
                Aún no estás en ningún proyecto.
              </p>
              <a
                href="/projects"
                class="inline-block px-6 py-2 bg-amber-400/20 hover:bg-amber-400/30 border border-amber-400/40 text-amber-300 rounded-lg text-xs font-bold uppercase tracking-widest transition-all"
              >
                Unirse o crear un proyecto →
              </a>
            </section>
          )
        }

        <!-- ── Cerrar sesión ── -->
        <div class="flex justify-end pt-2">
          <form action="/api/auth/signout" method="get">
            <button
              type="submit"
              class="px-6 py-2.5 bg-red-900/40 hover:bg-red-800/50 border border-red-500/40 text-red-300 rounded-lg transition-all font-bold uppercase text-xs tracking-wider"
            >
              🚪 Cerrar sesión
            </button>
          </form>
        </div>
      </div>
    </div>
    <Footer />
  </main>
</Layout>

<script>
  const avatarInput = document.getElementById(
    "avatar-input",
  ) as HTMLInputElement | null;
  avatarInput?.addEventListener("change", () => {
    if (avatarInput.files && avatarInput.files.length > 0) {
      (
        document.getElementById("avatar-form") as HTMLFormElement | null
      )?.submit();
    }
  });
</script>

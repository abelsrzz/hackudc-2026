---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import patternSvg from "../assets/pattern.svg";
import { supabaseAdmin } from "../lib/supabase";
import UpvoteButton from "../components/UpvoteButton.astro";

// Auth
const accessToken = Astro.cookies.get("sb-access-token");
if (!accessToken) return Astro.redirect("/signin");

const {
  data: { user },
  error: userError,
} = await supabaseAdmin.auth.getUser(accessToken.value);
if (userError || !user) return Astro.redirect("/signin");

const { data: profile } = await supabaseAdmin
  .from("profiles")
  .select("role, name")
  .eq("id", user.id)
  .single();

const role = profile?.role?.toLowerCase();
const isModerator = role === "admin" || role === "mentor";

const errorMsg = Astro.url.searchParams.get("error");
const successMsg = Astro.url.searchParams.get("success");

// Obtener todas las fotos con el perfil del autor
const { data: photos } = await supabaseAdmin
  .from("photos")
  .select(
    `
    id,
    created_at,
    storage_path,
    caption,
    user_id,
    profiles (
      id,
      name
    )
  `,
  )
  .order("created_at", { ascending: false });

// Construir URLs públicas
const supabaseUrl = import.meta.env.SUPABASE_URL;
const photosWithUrls = (photos ?? []).map((p: any) => ({
  ...p,
  publicUrl: `${supabaseUrl}/storage/v1/object/public/photos/${p.storage_path}`,
}));

// Upvotes de fotos
const photoIds = photosWithUrls.map((p: any) => String(p.id));
const { data: photoUpvotesRaw } = photoIds.length
  ? await supabaseAdmin
      .from("upvotes")
      .select("entity_id, user_id")
      .eq("entity_type", "photo")
      .in("entity_id", photoIds)
  : { data: [] };

const photoUpvoteCount: Record<string, number> = {};
const userPhotoVotes = new Set<string>();
for (const v of photoUpvotesRaw ?? []) {
  photoUpvoteCount[v.entity_id] = (photoUpvoteCount[v.entity_id] ?? 0) + 1;
  if (v.user_id === user.id) userPhotoVotes.add(v.entity_id);
}
---

<Layout title="Fotos — HackUDC">
  <main class="relative min-h-screen overflow-hidden">
    <!-- Background layers -->
    <div
      class="absolute inset-0 pointer-events-none z-0 opacity-80"
      style={`background-image: url(${patternSvg.src}); background-repeat: repeat; background-size: 304px 304px;`}
    >
    </div>
    <div class="absolute inset-0 bg-[#0a0011]/80 pointer-events-none z-0"></div>
    <div
      class="absolute inset-0 pointer-events-none z-0"
      style="background: radial-gradient(ellipse at center, transparent 20%, rgba(0,0,0,0.6) 80%, rgba(0,0,0,0.97) 100%);"
    >
    </div>

    <div
      class="relative z-20 flex flex-col items-center min-h-screen pt-12 pb-16 px-4"
    >
      <!-- Cabecera -->
      <div class="w-full max-w-5xl flex items-center justify-between mb-10">
        <a
          href="/dashboard"
          class="text-amber-300 hover:text-white font-bold uppercase tracking-widest text-sm transition-colors"
        >
          ← Dashboard
        </a>
        <a
          href="/profile"
          class="flex items-center gap-2 px-4 py-2 bg-black/40 hover:bg-black/60 border border-amber-400/30 hover:border-amber-400/60 text-amber-200 rounded-lg transition-all duration-300 font-bold uppercase text-xs tracking-wider"
        >
          <span
            class="w-6 h-6 rounded-full bg-amber-400/20 border border-amber-400 flex items-center justify-center text-amber-300 text-xs font-black"
          >
            {user.email?.charAt(0).toUpperCase()}
          </span>
          Mi Perfil
        </a>
      </div>

      <!-- Título -->
      <h1
        class="text-4xl sm:text-5xl md:text-6xl font-black uppercase tracking-[0.2em] text-amber-300 drop-shadow-[0_4px_0_#7c3f00] mb-2 text-center"
      >
        📸 Fotos
      </h1>
      <p class="text-amber-100/50 mb-10 text-center text-sm tracking-wide">
        El álbum compartido de HackUDC {new Date().getFullYear()}
      </p>

      <!-- Alertas -->
      {
        errorMsg && (
          <div class="w-full max-w-5xl mb-5 px-5 py-3 rounded-lg border border-red-500/40 bg-red-900/20 text-red-300 text-sm font-medium">
            ⚠ {decodeURIComponent(errorMsg)}
          </div>
        )
      }
      {
        successMsg && (
          <div class="w-full max-w-5xl mb-5 px-5 py-3 rounded-lg border border-green-500/40 bg-green-900/20 text-green-300 text-sm font-medium">
            ✓ {decodeURIComponent(successMsg)}
          </div>
        )
      }

      <div class="w-full max-w-5xl space-y-8">
        <!-- Botón subir foto -->
        <div class="flex justify-end">
          <button
            id="btn-open-upload"
            class="flex items-center gap-2 px-6 py-3 bg-amber-400 text-black font-black tracking-[0.15em] uppercase text-xs rounded-lg hover:bg-amber-300 transition-all duration-300 hover:shadow-[0_0_20px_rgba(251,191,36,0.5)] hover:scale-[1.02] active:scale-[0.98]"
          >
            + Subir foto
          </button>
        </div>

        <!-- Modal de subida -->
        <div
          id="upload-modal"
          class="hidden fixed inset-0 z-50 items-center justify-center p-4"
        >
          <!-- Overlay -->
          <div
            id="modal-overlay"
            class="absolute inset-0 bg-black/70 backdrop-blur-sm"
          >
          </div>

          <div
            class="relative z-10 bg-[#0a0011] border border-amber-400/40 rounded-2xl shadow-[0_0_60px_rgba(251,191,36,0.2)] w-full max-w-md p-6"
          >
            <div class="flex items-center justify-between mb-5">
              <h2
                class="text-amber-300 font-black uppercase tracking-widest text-sm"
              >
                Subir foto
              </h2>
              <button
                id="btn-close-upload"
                class="text-amber-100/40 hover:text-amber-200 transition-colors text-xl leading-none"
              >
                ✕
              </button>
            </div>

            <!-- Pestañas -->
            <div class="flex gap-1 mb-4 bg-black/30 p-1 rounded-lg">
              <button
                id="tab-file"
                type="button"
                class="flex-1 py-1.5 text-xs font-bold uppercase tracking-widest rounded-md transition-all tab-active"
              >
                📁 Archivo
              </button>
              <button
                id="tab-camera"
                type="button"
                class="flex-1 py-1.5 text-xs font-bold uppercase tracking-widest rounded-md transition-all"
              >
                📹 Cámara
              </button>
            </div>

            <form
              id="upload-form"
              action="/api/photos/upload"
              method="post"
              enctype="multipart/form-data"
              class="space-y-4"
            >
              <!-- Panel: Archivo -->
              <div id="panel-file">
                <label
                  for="photo-input"
                  class="flex flex-col items-center justify-center gap-3 w-full h-40 border-2 border-dashed border-amber-400/30 hover:border-amber-400/60 rounded-xl cursor-pointer transition-all duration-300 bg-black/30 hover:bg-black/50 group"
                >
                  <span class="text-4xl">📷</span>
                  <span
                    class="text-amber-200/60 text-sm font-medium group-hover:text-amber-200 transition-colors"
                  >
                    Click o arrastra una imagen aquí
                  </span>
                  <span class="text-amber-100/30 text-xs"
                    >JPG, PNG, WebP, GIF · máx. 8 MB</span
                  >
                  <input
                    id="photo-input"
                    type="file"
                    name="photo"
                    accept="image/jpeg,image/png,image/webp,image/gif"
                    class="hidden"
                  />
                </label>
                <!-- Preview archivo -->
                <img
                  id="photo-preview"
                  class="hidden w-full max-h-48 object-cover rounded-xl border border-amber-400/20 mt-3"
                  alt="Preview"
                />
              </div>

              <!-- Panel: Cámara -->
              <div id="panel-camera" class="hidden space-y-3">
                <div
                  class="relative rounded-xl overflow-hidden bg-black border border-amber-400/20"
                >
                  <video
                    id="camera-video"
                    autoplay
                    playsinline
                    muted
                    class="w-full max-h-56 object-cover"></video>
                  <!-- Overlay cuando no hay cámara activa -->
                  <div
                    id="camera-placeholder"
                    class="absolute inset-0 flex flex-col items-center justify-center gap-2 text-amber-100/30"
                  >
                    <span class="text-4xl">📹</span>
                    <span class="text-xs">La cámara aparecerá aquí</span>
                  </div>
                </div>
                <!-- Preview captura -->
                <img
                  id="capture-preview"
                  class="hidden w-full max-h-48 object-cover rounded-xl border border-amber-400/30"
                  alt="Captura"
                />
                <canvas id="capture-canvas" class="hidden"></canvas>
                <div class="flex gap-2">
                  <button
                    id="btn-start-camera"
                    type="button"
                    class="flex-1 py-2.5 bg-black/50 hover:bg-black/70 border border-amber-400/30 hover:border-amber-400/60 text-amber-300 font-bold uppercase text-xs tracking-widest rounded-lg transition-all"
                  >
                    Activar cámara
                  </button>
                  <button
                    id="btn-capture"
                    type="button"
                    class="hidden flex-1 py-2.5 bg-amber-400/20 hover:bg-amber-400/30 border border-amber-400/50 text-amber-300 font-bold uppercase text-xs tracking-widest rounded-lg transition-all"
                  >
                    📸 Capturar
                  </button>
                  <button
                    id="btn-retake"
                    type="button"
                    class="hidden px-4 py-2.5 bg-black/40 hover:bg-black/60 border border-amber-400/20 text-amber-200/50 hover:text-amber-200 font-bold uppercase text-xs tracking-widest rounded-lg transition-all"
                  >
                    Repetir
                  </button>
                </div>
              </div>

              <!-- Caption opcional (compartido) -->
              <input
                type="text"
                name="caption"
                placeholder="Añade una descripción (opcional)"
                maxlength={200}
                class="w-full px-4 py-2.5 bg-black/50 border-2 border-amber-400/30 rounded-lg text-amber-100 placeholder-amber-100/30 focus:outline-none focus:border-amber-300 focus:ring-1 focus:ring-amber-300 transition-all text-sm"
              />

              <button
                id="btn-submit"
                type="submit"
                class="w-full py-3 bg-amber-400 text-black font-black tracking-[0.15em] uppercase text-xs rounded-lg hover:bg-amber-300 transition-all duration-300 hover:shadow-[0_0_15px_rgba(251,191,36,0.4)]"
              >
                Publicar foto
              </button>
            </form>
          </div>
        </div>

        <!-- Cuadrícula de fotos -->
        {
          photosWithUrls.length === 0 ? (
            <div class="text-center py-24 text-amber-100/30 text-sm italic">
              Aún no hay fotos. ¡Sé el primero en publicar! 📸
            </div>
          ) : (
            <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
              {photosWithUrls.map((photo: any) => {
                const isOwner = photo.user_id === user.id;
                const canDelete = isOwner || isModerator;
                const authorName =
                  (photo.profiles as any)?.name ?? photo.user_id.slice(0, 8);
                return (
                  <div class="break-inside-avoid bg-black/40 backdrop-blur-sm rounded-xl border border-amber-400/15 overflow-hidden hover:border-amber-400/35 transition-all duration-300 group">
                    <a
                      href={photo.publicUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      <img
                        src={photo.publicUrl}
                        alt={photo.caption ?? `Foto de ${authorName}`}
                        loading="lazy"
                        class="w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                      />
                    </a>
                    <div class="px-4 py-3 flex items-start justify-between gap-2">
                      <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-2 mb-1">
                          <span class="w-5 h-5 rounded-full bg-amber-400/20 border border-amber-400/40 flex items-center justify-center text-amber-300 text-[10px] font-black shrink-0">
                            {authorName.charAt(0).toUpperCase()}
                          </span>
                          <span class="text-amber-200/80 text-xs font-bold truncate">
                            {authorName}
                            {isOwner && (
                              <span class="ml-1 text-amber-400/40 font-normal">
                                (tú)
                              </span>
                            )}
                          </span>
                        </div>
                        {photo.caption && (
                          <p class="text-amber-100/50 text-xs leading-snug break-words">
                            {photo.caption}
                          </p>
                        )}
                        <p class="text-amber-100/25 text-xs mt-1">
                          {new Date(photo.created_at).toLocaleString("es-ES", {
                            day: "2-digit",
                            month: "short",
                            hour: "2-digit",
                            minute: "2-digit",
                          })}
                        </p>
                      </div>
                      <!-- Acciones: upvote + borrar -->
                      <div class="flex flex-col items-end gap-2 shrink-0">
                        <UpvoteButton
                          entityType="photo"
                          entityId={String(photo.id)}
                          count={photoUpvoteCount[String(photo.id)] ?? 0}
                          voted={userPhotoVotes.has(String(photo.id))}
                        />
                        {canDelete && (
                          <form
                            action="/api/photos/delete"
                            method="post"
                            onsubmit="return confirm('¿Eliminar esta foto?')"
                          >
                            <input
                              type="hidden"
                              name="photo_id"
                              value={photo.id}
                            />
                            <button
                              type="submit"
                              title="Eliminar foto"
                              class="w-7 h-7 flex items-center justify-center rounded-lg bg-black/20 hover:bg-red-900/40 border border-transparent hover:border-red-500/40 text-amber-100/20 hover:text-red-400 transition-all text-sm"
                            >
                              🗑
                            </button>
                          </form>
                        )}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          )
        }
      </div>
    </div>

    <Footer />
  </main>
</Layout>

<script>
  // ── Elementos ──────────────────────────────────────────
  const btnOpen = document.getElementById("btn-open-upload");
  const btnClose = document.getElementById("btn-close-upload");
  const overlay = document.getElementById("modal-overlay");
  const modal = document.getElementById("upload-modal");
  const form = document.getElementById("upload-form") as HTMLFormElement;

  const tabFile = document.getElementById("tab-file") as HTMLButtonElement;
  const tabCamera = document.getElementById("tab-camera") as HTMLButtonElement;
  const panelFile = document.getElementById("panel-file")!;
  const panelCamera = document.getElementById("panel-camera")!;

  const photoInput = document.getElementById("photo-input") as HTMLInputElement;
  const preview = document.getElementById("photo-preview") as HTMLImageElement;

  const video = document.getElementById("camera-video") as HTMLVideoElement;
  const canvas = document.getElementById("capture-canvas") as HTMLCanvasElement;
  const capturePreview = document.getElementById(
    "capture-preview",
  ) as HTMLImageElement;
  const cameraPlaceholder = document.getElementById("camera-placeholder")!;
  const btnStartCamera = document.getElementById(
    "btn-start-camera",
  ) as HTMLButtonElement;
  const btnCapture = document.getElementById(
    "btn-capture",
  ) as HTMLButtonElement;
  const btnRetake = document.getElementById("btn-retake") as HTMLButtonElement;

  let stream: MediaStream | null = null;
  let capturedBlob: Blob | null = null;
  let activeTab: "file" | "camera" = "file";

  const TAB_ACTIVE =
    "bg-amber-400/20 text-amber-300 border border-amber-400/40";
  const TAB_IDLE = "text-amber-100/40 hover:text-amber-200";

  // ── Modal ──────────────────────────────────────────────
  function openModal() {
    modal?.classList.remove("hidden");
    modal?.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    modal?.classList.remove("flex");
    modal?.classList.add("hidden");
    document.body.style.overflow = "";
    stopCamera();
    // Reset cámara
    capturedBlob = null;
    capturePreview.classList.add("hidden");
    btnCapture.classList.remove("hidden");
    btnRetake.classList.add("hidden");
    video.classList.remove("hidden");
    cameraPlaceholder.classList.remove("hidden");
  }

  btnOpen?.addEventListener("click", openModal);
  btnClose?.addEventListener("click", closeModal);
  overlay?.addEventListener("click", closeModal);

  // ── Pestañas ───────────────────────────────────────────
  function switchTab(tab: "file" | "camera") {
    activeTab = tab;
    if (tab === "file") {
      panelFile.classList.remove("hidden");
      panelCamera.classList.add("hidden");
      tabFile.className = `flex-1 py-1.5 text-xs font-bold uppercase tracking-widest rounded-md transition-all ${TAB_ACTIVE}`;
      tabCamera.className = `flex-1 py-1.5 text-xs font-bold uppercase tracking-widest rounded-md transition-all ${TAB_IDLE}`;
      stopCamera();
    } else {
      panelFile.classList.add("hidden");
      panelCamera.classList.remove("hidden");
      tabFile.className = `flex-1 py-1.5 text-xs font-bold uppercase tracking-widest rounded-md transition-all ${TAB_IDLE}`;
      tabCamera.className = `flex-1 py-1.5 text-xs font-bold uppercase tracking-widest rounded-md transition-all ${TAB_ACTIVE}`;
    }
  }

  // Inicializar estilos de pestañas
  tabFile.className = `flex-1 py-1.5 text-xs font-bold uppercase tracking-widest rounded-md transition-all ${TAB_ACTIVE}`;
  tabCamera.className = `flex-1 py-1.5 text-xs font-bold uppercase tracking-widest rounded-md transition-all ${TAB_IDLE}`;

  tabFile?.addEventListener("click", () => switchTab("file"));
  tabCamera?.addEventListener("click", () => switchTab("camera"));

  // ── Preview de archivo ─────────────────────────────────
  photoInput?.addEventListener("change", () => {
    const file = photoInput.files?.[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = (e) => {
        preview.src = e.target?.result as string;
        preview.classList.remove("hidden");
      };
      reader.readAsDataURL(file);
    }
  });

  // ── Cámara ─────────────────────────────────────────────
  async function startCamera() {
    try {
      stream = await navigator.mediaDevices.getUserMedia({
        video: {
          facingMode: "environment",
          width: { ideal: 1280 },
          height: { ideal: 720 },
        },
        audio: false,
      });
      video.srcObject = stream;
      cameraPlaceholder.classList.add("hidden");
      btnStartCamera.classList.add("hidden");
      btnCapture.classList.remove("hidden");
    } catch {
      alert(
        "No se pudo acceder a la cámara. Comprueba los permisos del navegador.",
      );
    }
  }

  function stopCamera() {
    stream?.getTracks().forEach((t) => t.stop());
    stream = null;
    video.srcObject = null;
    btnStartCamera.classList.remove("hidden");
    btnCapture.classList.add("hidden");
  }

  function captureFrame() {
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    const ctx = canvas.getContext("2d")!;
    ctx.drawImage(video, 0, 0);
    canvas.toBlob(
      (blob) => {
        if (!blob) return;
        capturedBlob = blob;
        capturePreview.src = canvas.toDataURL("image/jpeg");
        capturePreview.classList.remove("hidden");
        video.classList.add("hidden");
        btnCapture.classList.add("hidden");
        btnRetake.classList.remove("hidden");
        stopCamera();
      },
      "image/jpeg",
      0.92,
    );
  }

  btnStartCamera?.addEventListener("click", startCamera);
  btnCapture?.addEventListener("click", captureFrame);
  btnRetake?.addEventListener("click", () => {
    capturedBlob = null;
    capturePreview.classList.add("hidden");
    video.classList.remove("hidden");
    btnRetake.classList.add("hidden");
    startCamera();
  });

  // ── Submit: inyectar foto capturada si es cámara ────────
  form?.addEventListener("submit", (e) => {
    if (activeTab === "camera") {
      if (!capturedBlob) {
        e.preventDefault();
        alert("Primero captura una foto con la cámara.");
        return;
      }
      // Crear un File desde el blob y añadirlo al FormData manualmente
      e.preventDefault();
      const fd = new FormData(form);
      const file = new File([capturedBlob], `captura-${Date.now()}.jpg`, {
        type: "image/jpeg",
      });
      fd.set("photo", file);
      fetch("/api/photos/upload", { method: "POST", body: fd })
        .then((res) => {
          if (res.redirected) window.location.href = res.url;
          else window.location.reload();
        })
        .catch(() => window.location.reload());
    }
    // Si activeTab === "file", el submit normal con enctype multipart funciona
  });
</script>

---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import TasksPanel from "../components/TasksPanel.astro";
import patternSvg from "../assets/pattern.svg";
import { supabaseAdmin } from "../lib/supabase";

const accessToken = Astro.cookies.get("sb-access-token");
if (!accessToken) return Astro.redirect("/signin");

const {
  data: { user },
  error: userError,
} = await supabaseAdmin.auth.getUser(accessToken.value);
if (userError || !user) return Astro.redirect("/signin");

const { data: profile } = await supabaseAdmin
  .from("profiles")
  .select("role, name, avatar_url")
  .eq("id", user.id)
  .single();

const role = profile?.role?.toLowerCase();
if (role !== "mentor" && role !== "admin") return Astro.redirect("/dashboard");
---

<Layout title="Tareas — HackUDC">
  <main class="relative min-h-screen overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none z-0 opacity-80"
      style={`background-image: url(${patternSvg.src}); background-repeat: repeat; background-size: 304px 304px;`}
    >
    </div>
    <div class="absolute inset-0 bg-[#0a0011]/80 pointer-events-none z-0"></div>
    <div
      class="absolute inset-0 pointer-events-none z-0"
      style="background: radial-gradient(ellipse at center, transparent 20%, rgba(0,0,0,0.6) 80%, rgba(0,0,0,0.97) 100%);"
    >
    </div>

    <div
      class="relative z-20 flex flex-col items-center min-h-screen pt-12 pb-16 px-4"
    >
      <!-- Cabecera -->
      <div class="w-full max-w-5xl flex items-center justify-between mb-10">
        <a
          href="/dashboard"
          class="text-amber-300 hover:text-white font-bold uppercase tracking-widest text-sm transition-colors"
        >
          ← Dashboard
        </a>
        <a
          href="/profile"
          class="flex items-center gap-2 px-4 py-2 bg-black/40 hover:bg-black/60 border border-amber-400/30 hover:border-amber-400/60 text-amber-200 rounded-lg transition-all duration-300 font-bold uppercase text-xs tracking-wider"
        >
          {
            profile?.avatar_url ? (
              <img
                src={profile.avatar_url}
                alt=""
                class="w-6 h-6 rounded-full border border-amber-400 object-cover shrink-0"
              />
            ) : (
              <span class="w-6 h-6 rounded-full bg-amber-400/20 border border-amber-400 flex items-center justify-center text-amber-300 text-xs font-black">
                {user.email?.charAt(0).toUpperCase()}
              </span>
            )
          }
          Mi Perfil
        </a>
      </div>

      <!-- Título -->
      <h1
        class="text-4xl sm:text-5xl md:text-6xl font-black uppercase tracking-[0.2em] text-amber-300 drop-shadow-[0_4px_0_#7c3f00] mb-3 text-center"
      >
        Tareas
      </h1>
      <p class="text-amber-100/50 mb-8 text-center text-sm tracking-wide">
        Gestión de tareas del equipo de mentores
      </p>

      <div class="w-full max-w-5xl">
        <TasksPanel
          userId={user.id}
          userRole={profile?.role ?? ""}
          canManage={true}
          instanceId="global"
        />
      </div>
    </div>
    <Footer />
  </main>
</Layout>

const filterStatus = Astro.url.searchParams.get("status") || "all";

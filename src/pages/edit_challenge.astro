---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import patternSvg from "../assets/pattern.svg";
import { supabase } from "../lib/supabase";

const { cookies, redirect, url } = Astro;

// Verificar autenticación
const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) {
  return redirect("/signin");
}

let session;
try {
  session = await supabase.auth.setSession({
    refresh_token: refreshToken.value,
    access_token: accessToken.value,
  });
  if (session.error) {
    return redirect("/signin");
  }
} catch (error) {
  return redirect("/signin");
}

const user = session.data.user;

if (!user) {
  return redirect("/signin");
}

// Obtener perfil del usuario
const { data: profile, error: profileError } = await supabase
  .from("profiles")
  .select("role, sponsor_id")
  .eq("id", user.id)
  .single();

if (profileError || !profile || profile.role !== "Sponsor") {
  return redirect("/challenges");
}

// Obtener ID del challenge desde query params
const challengeId = url.searchParams.get("id");

if (!challengeId) {
  return redirect("/challenges");
}

// Obtener el challenge de la base de datos
const { data: challenge, error } = await supabase
  .from("challenges")
  .select("id, title, short_description, content_markdown, reward, sponsor_id")
  .eq("id", challengeId)
  .single();

if (error || !challenge) {
  return redirect("/challenges");
}

// Verificar que el usuario es el sponsor dueño
if (challenge.sponsor_id !== profile.sponsor_id) {
  return redirect("/challenges");
}
---

<Layout title="Editar Challenge">
  <main class="relative min-h-screen overflow-hidden">
    <!-- Background layers -->
    <div
      class="absolute inset-0 pointer-events-none z-0 opacity-80"
      style={`background-image: url(${patternSvg.src}); background-repeat: repeat; background-size: 304px 304px;`}
    >
    </div>
    <div class="absolute inset-0 bg-[#0a0011]/80 pointer-events-none z-0"></div>
    <div
      class="absolute inset-0 pointer-events-none z-0"
      style="background: radial-gradient(ellipse at center, transparent 20%, rgba(0,0,0,0.6) 80%, rgba(0,0,0,0.97) 100%);"
    >
    </div>

    <div
      class="relative z-20 flex flex-col items-center min-h-screen pt-20 pb-10 px-4"
    >
      <!-- Botón de volver -->
      <div class="w-full max-w-4xl mb-6">
        <a
          href={`/challenge?id=${challenge.id}`}
          class="inline-flex items-center gap-2 rounded-lg border-2 border-amber-200 px-6 py-3 font-bold uppercase tracking-[0.2em] text-amber-200 transition-all duration-300 hover:scale-105 hover:bg-amber-200 hover:text-black hover:shadow-[0_0_20px_rgba(251,191,36,0.3)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Volver
        </a>
      </div>

      <!-- Título -->
      <h1
        class="text-4xl sm:text-5xl md:text-6xl font-black uppercase tracking-[0.2em] text-amber-300 drop-shadow-[0_4px_0_#7c3f00] mb-12 text-center"
      >
        Editar Challenge
      </h1>

      <!-- Formulario -->
      <div
        class="w-full max-w-4xl bg-black/40 backdrop-blur-sm p-8 sm:p-12 rounded-xl border border-amber-400/20 shadow-[0_0_20px_rgba(251,191,36,0.1)]"
      >
        <form method="post" action="/api/challenges/update" class="space-y-6">
          <!-- ID oculto -->
          <input type="hidden" name="challenge_id" value={challenge.id} />

          <!-- Título -->
          <div>
            <label
              for="title"
              class="block text-amber-300 font-bold uppercase tracking-wider text-sm mb-2"
            >
              Título *
            </label>
            <input
              type="text"
              id="title"
              name="title"
              required
              value={challenge.title}
              class="w-full px-4 py-3 bg-black/50 border border-amber-400/30 rounded-lg text-amber-100 placeholder-amber-200/30 focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition-all"
              placeholder="Nombre del challenge"
            />
          </div>

          <!-- Descripción corta -->
          <div>
            <label
              for="short_description"
              class="block text-amber-300 font-bold uppercase tracking-wider text-sm mb-2"
            >
              Descripción Corta *
            </label>
            <input
              type="text"
              id="short_description"
              name="short_description"
              required
              value={challenge.short_description}
              class="w-full px-4 py-3 bg-black/50 border border-amber-400/30 rounded-lg text-amber-100 placeholder-amber-200/30 focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition-all"
              placeholder="Resumen breve del challenge"
            />
          </div>

          <!-- Contenido completo (Markdown) -->
          <div>
            <label
              for="content_markdown"
              class="block text-amber-300 font-bold uppercase tracking-wider text-sm mb-2"
            >
              Contenido Completo (Markdown) *
            </label>
            <textarea
              id="content_markdown"
              name="content_markdown"
              required
              rows="12"
              class="w-full px-4 py-3 bg-black/50 border border-amber-400/30 rounded-lg text-amber-100 placeholder-amber-200/30 focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition-all resize-vertical font-mono text-sm"
              placeholder="Descripción detallada del challenge en formato Markdown..."
              >{challenge.content_markdown}</textarea
            >
            <p class="text-amber-200/50 text-xs mt-2">
              Puedes usar Markdown: **negrita**, *cursiva*, # títulos, listas,
              etc.
            </p>
          </div>

          <!-- Recompensa -->
          <div>
            <label
              for="reward"
              class="block text-amber-300 font-bold uppercase tracking-wider text-sm mb-2"
            >
              Recompensa
            </label>
            <input
              type="text"
              id="reward"
              name="reward"
              value={challenge.reward || ""}
              class="w-full px-4 py-3 bg-black/50 border border-amber-400/30 rounded-lg text-amber-100 placeholder-amber-200/30 focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 transition-all"
              placeholder="Ej: 500€, Hardware, Servicios..."
            />
          </div>

          <!-- Botones -->
          <div class="flex gap-4 pt-4">
            <button
              type="submit"
              class="flex-1 px-8 py-4 bg-amber-400 text-black font-bold uppercase tracking-[0.2em] rounded-lg hover:bg-amber-300 hover:scale-[1.02] hover:shadow-[0_0_30px_rgba(251,191,36,0.4)] transition-all duration-300"
            >
              Guardar Cambios
            </button>
            <a
              href={`/challenge?id=${challenge.id}`}
              class="px-8 py-4 border-2 border-amber-400/50 text-amber-200 font-bold uppercase tracking-[0.2em] rounded-lg hover:border-amber-400 hover:bg-amber-400/10 transition-all duration-300 text-center"
            >
              Cancelar
            </a>
          </div>
        </form>
      </div>

      <div class="mt-10 w-full">
        <Footer />
      </div>
    </div>
  </main>
</Layout>

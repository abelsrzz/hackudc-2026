---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";

const { cookies, redirect } = Astro;

// Verificar autenticación
const access_token = cookies.get("sb-access-token")?.value;

if (!access_token) {
  return redirect("/signin");
}

const {
  data: { user },
  error: userError,
} = await supabase.auth.getUser(access_token);

if (userError || !user) {
  return redirect("/signin");
}

// Verificar que sea Admin
const { data: profile } = await supabase
  .from("profiles")
  .select("role")
  .eq("id", user.id)
  .single();

if (!profile || profile.role !== "Admin") {
  return new Response("No autorizado", { status: 403 });
}

const { data: usersData } = await supabase
  .from("profiles")
  .select("id, name, role, created_at");

// Ordenar usuarios por rol
const roleOrder = { Admin: 1, Mentor: 2, Sponsor: 3, Hacker: 4 };
const users = usersData?.sort((a, b) => {
  return (
    (roleOrder[a.role as keyof typeof roleOrder] || 5) -
    (roleOrder[b.role as keyof typeof roleOrder] || 5)
  );
});
---

<Layout title="Panel Admin">
  <style>
    .admin-container {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 2rem;
      font-family:
        -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue",
        Arial, sans-serif;
    }

    h1 {
      color: #1a1a1a;
      font-size: 2.5rem;
      margin-bottom: 2rem;
      text-align: center;
      font-weight: 700;
    }

    .users-table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .users-table thead {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
    }

    .users-table th {
      padding: 1rem;
      text-align: left;
      font-weight: 600;
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .users-table tbody tr {
      border-bottom: 1px solid #f0f0f0;
      transition: background-color 0.2s;
    }

    .users-table tbody tr:hover {
      background-color: #f8f9fa;
    }

    .users-table tbody tr:last-child {
      border-bottom: none;
    }

    .users-table td {
      padding: 1rem;
      color: #333;
    }

    .user-id {
      font-family: "Courier New", monospace;
      color: #666;
      font-size: 0.9rem;
    }

    .user-name {
      font-weight: 500;
      color: #1a1a1a;
    }

    .role-select {
      padding: 0.5rem 1rem;
      border: 2px solid #e0e0e0;
      border-radius: 6px;
      background-color: white;
      font-size: 0.95rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      min-width: 120px;
    }

    .role-select:hover {
      border-color: #667eea;
    }

    .role-select:focus {
      outline: none;
      border-color: #667eea;
      box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .role-Admin {
      background-color: #fef3c7;
      color: #92400e;
    }
    .role-Mentor {
      background-color: #dbeafe;
      color: #1e40af;
    }
    .role-Sponsor {
      background-color: #dcfce7;
      color: #166534;
    }
    .role-Hacker {
      background-color: #f3e8ff;
      color: #6b21a8;
    }

    .date-cell {
      color: #666;
      font-size: 0.9rem;
    }

    .empty-state {
      text-align: center;
      padding: 3rem;
      color: #666;
      font-size: 1.1rem;
    }
  </style>

  <div class="admin-container">
    <h1>Panel de Administración</h1>

    {
      users && users.length > 0 ? (
        <table class="users-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Nombre</th>
              <th>Rol</th>
              <th>Fecha de Creación</th>
            </tr>
          </thead>
          <tbody>
            {users.map((user) => (
              <tr>
                <td class="user-id">{user.id.slice(0, 8)}...</td>
                <td class="user-name">{user.name || "Sin nombre"}</td>
                <td>
                  <select
                    data-user-id={user.id}
                    class={`role-select role-${user.role}`}
                    value={user.role}
                  >
                    <option value="Admin">👑 Admin</option>
                    <option value="Mentor">🎓 Mentor</option>
                    <option value="Sponsor">💼 Sponsor</option>
                    <option value="Hacker">💻 Hacker</option>
                  </select>
                </td>
                <td class="date-cell">
                  {new Date(user.created_at).toLocaleDateString("es-ES", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                    hour: "2-digit",
                    minute: "2-digit",
                  })}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="empty-state">No hay usuarios registrados.</p>
      )
    }
  </div>

  <script>
    // Establecer el valor seleccionado correctamente
    document.querySelectorAll(".role-select").forEach((select) => {
      const htmlSelect = select as HTMLSelectElement;
      const currentValue = htmlSelect.getAttribute("value");
      if (currentValue) {
        htmlSelect.value = currentValue;
      }
    });

    // Manejar cambios de rol
    document.querySelectorAll(".role-select").forEach((select) => {
      select.addEventListener("change", async (e) => {
        const target = e.target as HTMLSelectElement;
        const userId = target.dataset.userId;
        const newRole = target.value;
        const originalRole = target.getAttribute("value");

        if (!userId) return;

        try {
          const response = await fetch("/admin/update-role", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ userId, newRole }),
          });

          if (response.ok) {
            target.setAttribute("value", newRole);
            // Actualizar clase CSS para el color del badge
            target.className = `role-select role-${newRole}`;
            alert(`✅ Rol actualizado a ${newRole}`);
          } else {
            const error = await response.text();
            alert(`❌ Error: ${error}`);
            // Revertir el cambio
            target.value = originalRole || "Hacker";
          }
        } catch (error) {
          alert("❌ Error al actualizar el rol");
          // Revertir el cambio
          target.value = originalRole || "Hacker";
        }
      });
    });
  </script>
</Layout>

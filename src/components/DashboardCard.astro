---
interface Props {
  href: string;
  emoji: string;
  title: string;
  description: string;
  linkText: string;
  color?: "amber" | "blue" | "green" | "red";
}

const {
  href,
  emoji,
  title,
  description,
  linkText,
  color = "amber",
} = Astro.props;

const colors = {
  amber: {
    border:
      "border-amber-400/20 hover:border-amber-400/50 shadow-[0_0_20px_rgba(251,191,36,0.05)] hover:shadow-[0_0_25px_rgba(251,191,36,0.2)]",
    title: "text-amber-300",
    link: "text-amber-400/60 group-hover:text-amber-300",
  },
  blue: {
    border:
      "border-blue-400/20 hover:border-blue-400/50 shadow-[0_0_20px_rgba(96,165,250,0.05)] hover:shadow-[0_0_25px_rgba(96,165,250,0.2)]",
    title: "text-blue-300",
    link: "text-blue-400/60 group-hover:text-blue-300",
  },
  green: {
    border:
      "border-green-400/20 hover:border-green-400/50 shadow-[0_0_20px_rgba(74,222,128,0.05)] hover:shadow-[0_0_25px_rgba(74,222,128,0.2)]",
    title: "text-green-300",
    link: "text-green-400/60 group-hover:text-green-300",
  },
  red: {
    border:
      "border-red-500/20 hover:border-red-500/50 shadow-[0_0_20px_rgba(220,38,38,0.05)] hover:shadow-[0_0_25px_rgba(220,38,38,0.2)]",
    title: "text-red-400",
    link: "text-red-400/60 group-hover:text-red-300",
  },
};

const c = colors[color];
---

<a
  href={href}
  class={`group flex flex-col gap-3 bg-black/40 backdrop-blur-sm p-6 rounded-xl border ${c.border} transition-all duration-300 hover:scale-[1.02]`}
>
  <div class="text-3xl">{emoji}</div>
  <h2
    class={`${c.title} font-black uppercase tracking-widest text-sm group-hover:text-white transition-colors`}
  >
    {title}
  </h2>
  <p class="text-amber-100/50 text-sm leading-relaxed">{description}</p>
  <span
    class={`mt-auto ${c.link} text-xs font-bold uppercase tracking-widest transition-colors`}
  >
    {linkText} →
  </span>
</a>

---
import { createClient } from "@supabase/supabase-js";
import { marked } from "marked";

interface Props {
  channel: string;
  maxHeight?: string;
}

const { channel, maxHeight = "50vh" } = Astro.props;

// Configurar marked para mejor soporte de código
marked.setOptions({
  breaks: true,
  gfm: true,
});

// Crear un cliente fresco por petición para evitar conflictos con el singleton
const supabase = createClient(
  import.meta.env.SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
  {
    auth: {
      autoRefreshToken: false,
      persistSession: false,
    },
  },
);

const accessToken = Astro.cookies.get("sb-access-token");

let userId = "";
let userName = "Usuario";
let userRole = "";
let messages: any[] = [];
let isAuthenticated = false;

if (accessToken) {
  const {
    data: { user },
    error: userError,
  } = await supabase.auth.getUser(accessToken.value);

  if (!userError && user) {
    isAuthenticated = true;
    userId = user.id;

    const { data: profile } = await supabase
      .from("profiles")
      .select("name, role, avatar_url")
      .eq("id", user.id)
      .single();

    userName = profile?.name || "Usuario";
    userRole = profile?.role || "";

    const { data: initialMessages } = await supabase
      .from("messages")
      .select(
        `
        id,
        content,
        created_at,
        edited_at,
        user_id,
        reply_to,
        attachment_path,
        profiles (
          name,
          role,
          avatar_url
        )
      `,
      )
      .eq("channel", channel)
      .order("created_at", { ascending: true });

    messages = initialMessages || [];
  }
}

function roleStyles(role: string | undefined, isOwn: boolean) {
  const r = role?.toLowerCase();
  if (r === "mentor") return {
    msg: "bg-blue-900/20 border-blue-400/35 hover:border-blue-400/60",
    avatar: "bg-blue-400/25 border-blue-400/60 text-blue-200",
    name: "text-blue-300",
    ring: "hover:ring-blue-400/50",
  };
  if (r === "admin") return {
    msg: "bg-red-900/20 border-red-400/35 hover:border-red-400/60",
    avatar: "bg-red-400/25 border-red-400/60 text-red-200",
    name: "text-red-300",
    ring: "hover:ring-red-400/50",
  };
  if (r === "sponsor") return {
    msg: "bg-green-900/20 border-green-400/35 hover:border-green-400/60",
    avatar: "bg-green-400/25 border-green-400/60 text-green-200",
    name: "text-green-300",
    ring: "hover:ring-green-400/50",
  };
  if (isOwn) return {
    msg: "bg-amber-900/25 border-amber-500/30 hover:border-amber-400/60",
    avatar: "bg-amber-400/40 border-amber-300/70 text-amber-100",
    name: "text-amber-300",
    ring: "hover:ring-amber-400/50",
  };
  return {
    msg: "bg-black/30 border-amber-400/10 hover:border-amber-400/30",
    avatar: "bg-amber-400/20 border-amber-400/50 text-amber-300",
    name: "text-amber-200",
    ring: "hover:ring-amber-400/50",
  };
}

function roleBadge(role: string | undefined) {
  const r = role?.toLowerCase();
  if (r === "mentor") return { label: "Mentor", cls: "bg-blue-400/15 border border-blue-400/40 text-blue-300" };
  if (r === "admin") return { label: "Admin", cls: "bg-red-400/15 border border-red-400/40 text-red-300" };
  if (r === "sponsor") return { label: "Sponsor", cls: "bg-green-400/15 border border-green-400/40 text-green-300" };
  return null;
}
---

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" />

<style>
  .message-content pre {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    margin: 0.5rem 0;
  }

  .message-content pre code {
    border-radius: 0.75rem;
  }

  .copy-code-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.25rem 0.5rem;
    background: rgba(251, 191, 36, 0.1);
    border: 1px solid rgba(251, 191, 36, 0.3);
    color: rgb(252, 211, 77);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 0.375rem;
    cursor: pointer;
    transition: all 0.2s;
    z-index: 10;
  }

  .copy-code-btn:hover {
    background: rgba(251, 191, 36, 0.2);
    border-color: rgba(251, 191, 36, 0.5);
    color: rgb(254, 243, 199);
  }

  .copy-code-btn.copied {
    background: rgba(34, 197, 94, 0.2);
    border-color: rgba(34, 197, 94, 0.5);
    color: rgb(134, 239, 172);
  }
</style>

{isAuthenticated && (
<div class="chat-component w-full">
  <p class="text-amber-200/50 text-xs uppercase tracking-widest mb-3 font-bold">
    Chat — {channel}
  </p>

  <!-- Caja de mensajes -->
  <div
    id={`chat-box-${channel}`}
    class="chat-box bg-black/40 backdrop-blur-sm border border-amber-400/20 rounded-xl p-4 overflow-y-auto space-y-3 mb-3"
    style={`max-height: ${maxHeight}; min-height: 300px;`}
  >
    {
      messages.length === 0 && (
        <p class="text-amber-100/30 text-sm italic text-center py-8">
          No hay mensajes aún. ¡Sé el primero en escribir!
        </p>
      )
    }
    {
      messages.map((msg: any) => {
        const isOwn = msg.user_id === userId;
        const styles = roleStyles(msg.profiles?.role, isOwn);
        const badge = roleBadge(msg.profiles?.role);
        return (
          <div
            class={`message group rounded-lg p-4 transition-all duration-200 border ${styles.msg}`}
            data-message-id={msg.id}
            data-user-id={msg.user_id}
          >
            <div
              class={`flex items-start gap-2 mb-2 ${isOwn ? "flex-row-reverse justify-start" : "justify-between"}`}
            >
              <div
                class={`flex items-center gap-2 ${isOwn ? "flex-row-reverse" : ""}`}
              >
                <a
                  href={msg.user_id === userId ? "/profile" : `/user/${msg.user_id}`}
                  class={`w-8 h-8 rounded-full flex items-center justify-center text-xs font-black shrink-0 border hover:ring-2 transition-all ${styles.avatar} ${styles.ring}`}
                >
                  {msg.profiles?.avatar_url ? (
                    <img
                      src={msg.profiles.avatar_url}
                      alt={msg.profiles?.name ?? ""}
                      class="w-full h-full rounded-full object-cover"
                    />
                  ) : (
                    msg.profiles?.name?.charAt(0).toUpperCase() || "?"
                  )}
                </a>
                <a
                  href={msg.user_id === userId ? "/profile" : `/user/${msg.user_id}`}
                  class={`font-semibold text-sm hover:underline hover:underline-offset-2 transition-all ${styles.name}`}
                >
                  {msg.profiles?.name || "Usuario"}
                </a>
                {badge && (
                  <span class={`text-[10px] px-1.5 py-0.5 rounded-full font-bold uppercase tracking-widest ${badge.cls}`}>
                    {badge.label}
                  </span>
                )}
                {msg.edited_at && (
                  <span class="text-amber-400/50 text-xs italic">
                    (editado)
                  </span>
                )}
              </div>
              <span class="text-amber-400/40 text-xs shrink-0 mt-0.5">
                {new Date(msg.created_at).toLocaleString()}
              </span>
            </div>
            {msg.reply_to && (
              <div
                class={`mb-2 text-amber-400/60 text-xs italic ${isOwn ? "mr-10 text-right" : "ml-10"}`}
              >
                ↳ Respondiendo a un mensaje anterior
              </div>
            )}
            {(() => {
              const isDeleted = msg.content.startsWith("__DELETED__:");
              const deletedBy = isDeleted ? msg.content.slice("__DELETED__:".length) : "";
              const supabaseUrl = import.meta.env.SUPABASE_URL;
              return isDeleted ? (
                <div class={`${isOwn ? "mr-10 text-right" : "ml-10"} text-amber-400/35 text-sm italic leading-relaxed select-none`}>
                  🗑️ Mensaje borrado por {deletedBy}
                </div>
              ) : (
                <div class={`${isOwn ? "mr-10 flex flex-col items-end" : "ml-10"}`}>
                  {msg.attachment_path && (
                    <a
                      href={`${supabaseUrl}/storage/v1/object/public/photos/${msg.attachment_path}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block mb-2 rounded-lg overflow-hidden border border-amber-400/20 hover:border-amber-400/40 transition-all max-w-md"
                    >
                      <img
                        src={`${supabaseUrl}/storage/v1/object/public/photos/${msg.attachment_path}`}
                        alt="Imagen adjunta"
                        class="w-full h-auto object-cover"
                      />
                    </a>
                  )}
                  {msg.content && (
                    <div
                      class={`message-content text-amber-100/90 text-sm leading-relaxed prose prose-invert prose-sm max-w-none prose-pre:bg-black/50 prose-pre:border prose-pre:border-amber-400/20 prose-code:text-amber-200 ${isOwn ? 'text-right' : ''}`}
                      set:html={marked(msg.content)}
                    />
                  )}
                </div>
              );
            })()}
            {(() => {
              const isDeleted = msg.content.startsWith("__DELETED__:");
              const isMod = userRole?.toLowerCase() === "admin" || userRole?.toLowerCase() === "mentor";
              if (isDeleted) return null;
              return (
                <div class={`mt-2 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity ${isOwn ? "mr-10 justify-end" : "ml-10"}`}>
                  <button
                    class="reply-btn text-amber-400/70 hover:text-amber-300 text-xs font-semibold uppercase tracking-wide transition-colors"
                    data-reply-to={msg.id}
                  >
                    Responder
                  </button>
                  {isOwn && (
                    <button
                      class="edit-btn text-amber-400/70 hover:text-amber-300 text-xs font-semibold uppercase tracking-wide transition-colors"
                      data-message-id={msg.id}
                      data-content={msg.content}
                    >
                      Editar
                    </button>
                  )}
                  {(isOwn || isMod) && (
                    <button
                      class="delete-btn text-red-400/60 hover:text-red-400 text-xs font-semibold uppercase tracking-wide transition-colors"
                      data-message-id={msg.id}
                    >
                      Borrar
                    </button>
                  )}
                </div>
              );
            })()}
          </div>
        );
      })
    }
  </div>

  <!-- Indicador de respuesta -->
  <div
    id={`reply-indicator-${channel}`}
    class="reply-indicator bg-amber-500/10 border border-amber-400/30 rounded-lg px-4 py-2 mb-2 flex items-center justify-between"
    style="display:none;"
  >
    <span class="text-amber-300 text-sm">
      Respondiendo a: <span class="reply-to-preview font-bold italic"></span>
    </span>
    <button
      class="cancel-reply-btn text-amber-400/70 hover:text-amber-300 text-sm font-semibold uppercase tracking-wide transition-colors"
    >
      Cancelar
    </button>
  </div>

  <!-- Input de mensaje -->
  <div class="space-y-2">
    <!-- Botones de modo -->
    <div class="flex gap-2 items-center">
      <button
        class="mode-btn mode-normal bg-amber-400/20 border border-amber-400/40 text-amber-300 px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wide transition-all"
        data-mode="normal"
      >
        💬 Normal
      </button>
      <button
        class="mode-btn bg-black/40 border border-amber-400/10 text-amber-400/50 hover:text-amber-400/80 hover:border-amber-400/30 px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wide transition-all"
        data-mode="code"
      >
        💻 Código
      </button>
      <button
        class="attach-photo-btn ml-auto bg-black/40 border border-amber-400/10 text-amber-400/50 hover:text-amber-400/80 hover:border-amber-400/30 px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wide transition-all"
      >
        📎 Foto
      </button>
    </div>
    <div
      class="bg-black/40 backdrop-blur-sm border border-amber-400/20 rounded-xl p-3 flex gap-3"
    >
      <textarea
        class="message-input flex-1 bg-black/50 border border-amber-400/20 focus:border-amber-400/50 rounded-lg px-4 py-2.5 text-amber-100 placeholder-amber-400/30 outline-none transition-colors text-sm resize-none"
        placeholder="Escribe un mensaje... (soporta Markdown)"
        rows="1"
      ></textarea>
      <button
        class="send-btn px-5 py-2.5 bg-amber-500/20 hover:bg-amber-500/30 border border-amber-400/50 hover:border-amber-400/70 text-amber-300 font-bold uppercase text-xs tracking-wider rounded-lg transition-all duration-300 shadow-[0_0_10px_rgba(251,191,36,0.15)] hover:shadow-[0_0_15px_rgba(251,191,36,0.35)] self-end"
      >
        Enviar
      </button>
    </div>
  </div>

  <!-- Modal de subida de foto -->
  <div
    class="chat-photo-modal hidden fixed inset-0 z-50 items-center justify-center p-4"
  >
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm modal-overlay"></div>
    <div
      class="relative z-10 bg-[#0a0011] border border-amber-400/40 rounded-2xl shadow-[0_0_60px_rgba(251,191,36,0.2)] w-full max-w-md p-6"
    >
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-amber-300 font-black uppercase tracking-widest text-sm">
          Adjuntar foto
        </h2>
        <button class="close-modal-btn text-amber-100/40 hover:text-amber-200 transition-colors text-xl leading-none">
          ✕
        </button>
      </div>

      <!-- Pestañas -->
      <div class="flex gap-1 mb-4 bg-black/30 p-1 rounded-lg">
        <button
          class="tab-btn tab-file bg-amber-400/20 text-amber-300 border border-amber-400/40 flex-1 py-1.5 text-xs font-bold uppercase tracking-widest rounded-md transition-all"
          data-tab="file"
        >
          📁 Archivo
        </button>
        <button
          class="tab-btn tab-camera text-amber-100/40 hover:text-amber-200 flex-1 py-1.5 text-xs font-bold uppercase tracking-widest rounded-md transition-all"
          data-tab="camera"
        >
          📹 Cámara
        </button>
      </div>

      <!-- Panel: Archivo -->
      <div class="panel-file">
        <label
          class="photo-drop-zone flex flex-col items-center justify-center gap-3 w-full h-40 border-2 border-dashed border-amber-400/30 hover:border-amber-400/60 rounded-xl cursor-pointer transition-all duration-300 bg-black/30 hover:bg-black/50 group"
        >
          <span class="text-4xl">📷</span>
          <span class="text-amber-200/60 text-sm font-medium group-hover:text-amber-200 transition-colors">
            Click o arrastra una imagen aquí
          </span>
          <span class="text-amber-100/30 text-xs">JPG, PNG, WebP, GIF · máx. 8 MB</span>
          <input
            type="file"
            class="photo-file-input hidden"
            accept="image/jpeg,image/png,image/webp,image/gif"
          />
        </label>
        <img
          class="photo-preview hidden w-full max-h-48 object-cover rounded-xl border border-amber-400/20 mt-3"
          alt="Preview"
        />
      </div>

      <!-- Panel: Cámara -->
      <div class="panel-camera hidden space-y-3">
        <div class="relative rounded-xl overflow-hidden bg-black border border-amber-400/20">
          <video
            class="camera-video w-full max-h-56 object-cover"
            autoplay
            playsinline
            muted
          ></video>
          <div class="camera-placeholder absolute inset-0 flex flex-col items-center justify-center gap-2 text-amber-100/30">
            <span class="text-4xl">📹</span>
            <span class="text-xs">La cámara aparecerá aquí</span>
          </div>
        </div>
        <img
          class="capture-preview hidden w-full max-h-48 object-cover rounded-xl border border-amber-400/30"
          alt="Captura"
        />
        <canvas class="capture-canvas hidden"></canvas>
        <div class="flex gap-2">
          <button
            class="start-camera-btn flex-1 py-2.5 bg-black/50 hover:bg-black/70 border border-amber-400/30 hover:border-amber-400/60 text-amber-300 font-bold uppercase text-xs tracking-widest rounded-lg transition-all"
            type="button"
          >
            Activar cámara
          </button>
          <button
            class="capture-btn hidden flex-1 py-2.5 bg-amber-400/20 hover:bg-amber-400/30 border border-amber-400/50 text-amber-300 font-bold uppercase text-xs tracking-widest rounded-lg transition-all"
            type="button"
          >
            📸 Capturar
          </button>
          <button
            class="retake-btn hidden px-4 py-2.5 bg-black/40 hover:bg-black/60 border border-amber-400/20 text-amber-200/50 hover:text-amber-200 font-bold uppercase text-xs tracking-widest rounded-lg transition-all"
            type="button"
          >
            Repetir
          </button>
        </div>
      </div>

      <button
        class="upload-photo-btn w-full mt-4 py-3 bg-amber-400 text-black font-black tracking-[0.15em] uppercase text-xs rounded-lg hover:bg-amber-300 transition-all duration-300 hover:shadow-[0_0_15px_rgba(251,191,36,0.4)]"
      >
        Adjuntar foto
      </button>
    </div>
  </div>
</div>
)}

<script define:vars={{ userId, userName, userRole, channel, supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL || import.meta.env.SUPABASE_URL, supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY || import.meta.env.SUPABASE_KEY }}>
  // Importar highlight.js
  const hljs = window.hljs;

  // Scope to this specific chat instance using the channel id
  const chatBox = document.getElementById(`chat-box-${channel}`);
  const replyIndicator = document.getElementById(`reply-indicator-${channel}`);

  // Use the closest parent .chat-component to scope the other elements
  const chatRoot = chatBox?.closest(".chat-component");
  const messageInput = chatRoot?.querySelector(".message-input");
  const sendBtn = chatRoot?.querySelector(".send-btn");
  const replyToPreview = replyIndicator?.querySelector(".reply-to-preview");
  const cancelReplyBtn = replyIndicator?.querySelector(".cancel-reply-btn");

  // Modal de foto
  const modal = chatRoot?.querySelector(".chat-photo-modal");
  const closeModalBtn = modal?.querySelector(".close-modal-btn");
  const modalOverlay = modal?.querySelector(".modal-overlay");
  const attachPhotoBtn = chatRoot?.querySelector(".attach-photo-btn");
  const tabBtns = modal?.querySelectorAll(".tab-btn");
  const panelFile = modal?.querySelector(".panel-file");
  const panelCamera = modal?.querySelector(".panel-camera");
  const photoInput = modal?.querySelector(".photo-file-input");
  const photoPreview = modal?.querySelector(".photo-preview");
  const dropZone = modal?.querySelector(".photo-drop-zone");
  const video = modal?.querySelector(".camera-video");
  const canvas = modal?.querySelector(".capture-canvas");
  const capturePreview = modal?.querySelector(".capture-preview");
  const cameraPlaceholder = modal?.querySelector(".camera-placeholder");
  const startCameraBtn = modal?.querySelector(".start-camera-btn");
  const captureBtn = modal?.querySelector(".capture-btn");
  const retakeBtn = modal?.querySelector(".retake-btn");
  const uploadPhotoBtn = modal?.querySelector(".upload-photo-btn");

  // Modo de entrada
  const modeBtns = chatRoot?.querySelectorAll(".mode-btn");
  let currentMode = "normal"; // "normal" | "code"
  let capturedBlob = null;
  let stream = null;
  let activeTab = "file";

  let replyTo = null;
  let replyToText = null;
  let attachmentPath = null; // Para almacenar la ruta de la foto subida
  const isModerator = userRole?.toLowerCase() === "admin" || userRole?.toLowerCase() === "mentor";

  function isDeletedContent(content) {
    return typeof content === "string" && content.startsWith("__DELETED__:");
  }
  function deletedByName(content) {
    return content.slice("__DELETED__:".length);
  }

  function addMessageToDOM(msg) {
    // Remove empty state message if present
    const emptyMsg = chatBox?.querySelector("p.italic");
    if (emptyMsg) emptyMsg.remove();

    const isOwn = msg.user_id === userId;
    const messageDiv = document.createElement("div");
    messageDiv.dataset.messageId = msg.id;
    messageDiv.dataset.userId = msg.user_id;

    const name = msg.profiles?.name || userName;
    const avatarUrl = msg.profiles?.avatar_url || null;
    const avatarInner = avatarUrl
      ? `<img src="${avatarUrl}" alt="${name.replace(/"/g, "&quot;")}" style="width:100%;height:100%;border-radius:50%;object-fit:cover;" />`
      : name.charAt(0).toUpperCase();
    const time = msg.created_at
      ? new Date(msg.created_at).toLocaleString()
      : "";

    const role = msg.profiles?.role?.toLowerCase();
    let msgBg, avatarBase, nameColor, ringColor, badgeHTML = "";
    if (role === "mentor") {
      msgBg = "bg-blue-900/20 border-blue-400/35 hover:border-blue-400/60";
      avatarBase = "bg-blue-400/25 border-blue-400/60 text-blue-200";
      nameColor = "text-blue-300";
      ringColor = "hover:ring-blue-400/50";
      badgeHTML = `<span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold uppercase tracking-widest bg-blue-400/15 border border-blue-400/40 text-blue-300">Mentor</span>`;
    } else if (role === "admin") {
      msgBg = "bg-red-900/20 border-red-400/35 hover:border-red-400/60";
      avatarBase = "bg-red-400/25 border-red-400/60 text-red-200";
      nameColor = "text-red-300";
      ringColor = "hover:ring-red-400/50";
      badgeHTML = `<span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold uppercase tracking-widest bg-red-400/15 border border-red-400/40 text-red-300">Admin</span>`;
    } else if (role === "sponsor") {
      msgBg = "bg-green-900/20 border-green-400/35 hover:border-green-400/60";
      avatarBase = "bg-green-400/25 border-green-400/60 text-green-200";
      nameColor = "text-green-300";
      ringColor = "hover:ring-green-400/50";
      badgeHTML = `<span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold uppercase tracking-widest bg-green-400/15 border border-green-400/40 text-green-300">Sponsor</span>`;
    } else if (isOwn) {
      msgBg = "bg-amber-900/25 border-amber-500/30 hover:border-amber-400/60";
      avatarBase = "bg-amber-400/40 border-amber-300/70 text-amber-100";
      nameColor = "text-amber-300";
      ringColor = "hover:ring-amber-400/50";
    } else {
      msgBg = "bg-black/30 border-amber-400/10 hover:border-amber-400/30";
      avatarBase = "bg-amber-400/20 border-amber-400/50 text-amber-300";
      nameColor = "text-amber-200";
      ringColor = "hover:ring-amber-400/50";
    }

    messageDiv.className = `message group border rounded-lg p-4 transition-all duration-200 ${msgBg}`;

    const avatarClass = `w-8 h-8 rounded-full border flex items-center justify-center text-xs font-black shrink-0 hover:ring-2 transition-all ${avatarBase} ${ringColor}`;
    const nameClass = `${nameColor} font-semibold text-sm hover:underline hover:underline-offset-2`;
    const headerDir = isOwn ? "flex-row-reverse" : "";
    const nameRowDir = isOwn ? "flex-row-reverse" : "";
    const contentClass = isOwn ? "mr-10 text-right" : "ml-10";
    const actionsClass = isOwn ? "mr-10 justify-end" : "ml-10";

    let html = `
      <div class="flex items-start gap-2 mb-2 ${headerDir}">
        <div class="flex items-center gap-2 flex-wrap ${nameRowDir}">
          <a href="${msg.user_id === userId ? '/profile' : '/user/' + msg.user_id}" class="${avatarClass}">${avatarInner}</a>
          <a href="${msg.user_id === userId ? '/profile' : '/user/' + msg.user_id}" class="${nameClass}">${name}</a>
          ${badgeHTML}
        </div>
        <span class="text-amber-400/40 text-xs shrink-0 mt-0.5" style="margin-${isOwn ? "right" : "left"}:auto">${time}</span>
      </div>
    `;

    if (msg.reply_to) {
      html += `<div class="${contentClass} mb-2 text-amber-400/60 text-xs italic">↳ Respondiendo a un mensaje anterior</div>`;
    }

    if (isDeletedContent(msg.content)) {
      html += `<div class="${contentClass} text-amber-400/35 text-sm italic leading-relaxed select-none">🗑️ Mensaje borrado por ${deletedByName(msg.content)}</div>`;
    } else {
      // Contenedor con alineación
      const containerClass = isOwn ? "mr-10 flex flex-col items-end" : "ml-10";
      html += `<div class="${containerClass}">`;
      
      // Attachment
      if (msg.attachment_path) {
        const photoUrl = `${supabaseUrl}/storage/v1/object/public/photos/${msg.attachment_path}`;
        html += `<a href="${photoUrl}" target="_blank" rel="noopener noreferrer" class="block mb-2 rounded-lg overflow-hidden border border-amber-400/20 hover:border-amber-400/40 transition-all max-w-md"><img src="${photoUrl}" alt="Imagen adjunta" class="w-full h-auto object-cover" /></a>`;
      }
      // Content con markdown
      if (msg.content) {
        // Parsear markdown en cliente usando marked (necesitamos cargarlo globalmente)
        const parsedContent = window.marked?.parse ? window.marked.parse(msg.content) : msg.content.replace(/\n/g, '<br>');
        html += `<div class="message-content text-amber-100/90 text-sm leading-relaxed prose prose-invert prose-sm max-w-none prose-pre:bg-black/50 prose-pre:border prose-pre:border-amber-400/20 prose-code:text-amber-200 ${isOwn ? 'text-right' : ''}">${parsedContent}</div>`;
      }
      html += `</div>`;
      html += `<div class="${actionsClass} mt-2 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">`;
      html += `<button class="reply-btn text-amber-400/70 hover:text-amber-300 text-xs font-semibold uppercase tracking-wide transition-colors" data-reply-to="${msg.id}">Responder</button>`;
      if (isOwn) {
        html += `<button class="edit-btn text-amber-400/70 hover:text-amber-300 text-xs font-semibold uppercase tracking-wide transition-colors" data-message-id="${msg.id}" data-content="${msg.content.replace(/"/g, "&quot;")}">Editar</button>`;
      }
      if (isOwn || isModerator) {
        html += `<button class="delete-btn text-red-400/60 hover:text-red-400 text-xs font-semibold uppercase tracking-wide transition-colors" data-message-id="${msg.id}">Borrar</button>`;
      }
      html += `</div>`;
    }

    messageDiv.innerHTML = html;
    chatBox?.appendChild(messageDiv);
    
    // Aplicar syntax highlighting a los bloques de código
    if (hljs) {
      messageDiv.querySelectorAll('pre code').forEach((block) => {
        hljs.highlightElement(block);
      });
    }

    // Añadir botones de copiar a los bloques de código
    messageDiv.querySelectorAll('pre').forEach((pre) => {
      const code = pre.querySelector('code');
      if (code) {
        const copyBtn = document.createElement('button');
        copyBtn.className = 'copy-code-btn';
        copyBtn.textContent = 'Copiar';
        copyBtn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(code.textContent || '');
            copyBtn.textContent = '¡Copiado!';
            copyBtn.classList.add('copied');
            setTimeout(() => {
              copyBtn.textContent = 'Copiar';
              copyBtn.classList.remove('copied');
            }, 2000);
          } catch {
            copyBtn.textContent = 'Error';
            setTimeout(() => {
              copyBtn.textContent = 'Copiar';
            }, 2000);
          }
        });
        pre.style.position = 'relative';
        pre.appendChild(copyBtn);
      }
    });
    
    chatBox?.scrollTo({ top: chatBox.scrollHeight, behavior: "smooth" });

    // Attach event listeners to new buttons
    messageDiv
      .querySelector(".reply-btn")
      ?.addEventListener("click", handleReplyClick);
    messageDiv
      .querySelector(".edit-btn")
      ?.addEventListener("click", handleEditClick);
    messageDiv
      .querySelector(".delete-btn")
      ?.addEventListener("click", handleDeleteClick);
  }

  async function sendMessage() {
    let content = messageInput?.value?.trim();
    if (!content && !attachmentPath) return;

    // Si está en modo código, envolver en triple backticks
    if (currentMode === "code" && content) {
      content = "```\n" + content + "\n```";
    }

    const body = { 
      content: content || "", 
      channel, 
      reply_to: replyTo,
      attachment_path: attachmentPath 
    };

    try {
      const response = await fetch("/api/chat/send", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });

      if (response.ok) {
        if (messageInput) {
          messageInput.value = "";
          messageInput.style.height = "auto";
        }
        clearReply();
        attachmentPath = null;
      } else {
        const errText = await response.text();
        alert("Error al enviar: " + errText);
      }
    } catch (err) {
      alert("Error de conexión.");
    }
  }

  function clearReply() {
    replyTo = null;
    replyToText = null;
    if (replyIndicator) replyIndicator.style.display = "none";
    if (replyToPreview) replyToPreview.textContent = "";
  }

  function handleReplyClick(e) {
    const btn = e.currentTarget;
    replyTo = btn.dataset.replyTo;
    // Show a snippet of the message content as preview
    const msgDiv = btn.closest(".message");
    const contentEl = msgDiv?.querySelector(".text-amber-100\\/90");
    replyToText = contentEl?.textContent?.trim().slice(0, 60) || replyTo;
    if (replyToPreview) replyToPreview.textContent = replyToText;
    if (replyIndicator) replyIndicator.style.display = "flex";
    messageInput?.focus();
  }

  async function handleDeleteClick(e) {
    const btn = e.currentTarget;
    const messageId = btn.dataset.messageId;
    if (!confirm("¿Estás seguro de que quieres borrar este mensaje?")) return;

    try {
      const response = await fetch("/api/chat/delete", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ messageId }),
      });
      if (!response.ok) {
        alert("Error al borrar el mensaje.");
      }
      // El borrado se refleja en el DOM vía Realtime (DELETE o UPDATE)
    } catch {
      alert("Error de conexión.");
    }
  }

  async function handleEditClick(e) {
    const btn = e.currentTarget;
    const messageId = btn.dataset.messageId;
    const currentContent = btn.dataset.content;
    const newContent = prompt("Editar mensaje:", currentContent);
    if (!newContent || newContent === currentContent) return;

    try {
      const response = await fetch("/api/chat/edit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ messageId, newContent }),
      });
      if (response.ok) {
        // Update the content in the DOM
        const msgDiv = btn.closest(".message");
        const contentEl = msgDiv?.querySelector(".text-amber-100\\/90");
        if (contentEl) contentEl.textContent = newContent;
        btn.dataset.content = newContent;
        // Add edited indicator if not already there
        const nameRow = msgDiv?.querySelector(".flex.items-center.gap-2");
        if (nameRow && !nameRow.querySelector(".edited-tag")) {
          const tag = document.createElement("span");
          tag.className = "edited-tag text-amber-400/50 text-xs italic";
          tag.textContent = "(editado)";
          nameRow.appendChild(tag);
        }
      } else {
        alert("Error al editar el mensaje.");
      }
    } catch {
      alert("Error de conexión.");
    }
  }

  // Attach handlers to existing reply/edit/delete buttons
  chatRoot?.querySelectorAll(".reply-btn").forEach((btn) => {
    btn.addEventListener("click", handleReplyClick);
  });
  chatRoot?.querySelectorAll(".edit-btn").forEach((btn) => {
    btn.addEventListener("click", handleEditClick);
  });
  chatRoot?.querySelectorAll(".delete-btn").forEach((btn) => {
    btn.addEventListener("click", handleDeleteClick);
  });

  cancelReplyBtn?.addEventListener("click", clearReply);

  sendBtn?.addEventListener("click", sendMessage);

  messageInput?.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  // Auto-resize textarea
  messageInput?.addEventListener("input", () => {
    messageInput.style.height = "auto";
    messageInput.style.height = messageInput.scrollHeight + "px";
  });

  // ══════════════════════════════════════════════════════════════
  // Modal de foto
  // ══════════════════════════════════════════════════════════════
  function openPhotoModal() {
    modal?.classList.remove("hidden");
    modal?.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function closePhotoModal() {
    modal?.classList.remove("flex");
    modal?.classList.add("hidden");
    document.body.style.overflow = "";
    stopCamera();
    capturedBlob = null;
    if (photoInput) photoInput.value = "";
    photoPreview?.classList.add("hidden");
    capturePreview?.classList.add("hidden");
    if (captureBtn) captureBtn.classList.remove("hidden");
    if (retakeBtn) retakeBtn.classList.add("hidden");
    if (video) video.classList.remove("hidden");
    cameraPlaceholder?.classList.remove("hidden");
  }

  attachPhotoBtn?.addEventListener("click", openPhotoModal);
  closeModalBtn?.addEventListener("click", closePhotoModal);
  modalOverlay?.addEventListener("click", closePhotoModal);

  // Tabs
  function switchPhotoTab(tab) {
    activeTab = tab;
    tabBtns?.forEach((btn) => {
      if (btn.dataset.tab === tab) {
        btn.className = "tab-btn flex-1 py-1.5 text-xs font-bold uppercase tracking-widest rounded-md transition-all bg-amber-400/20 text-amber-300 border border-amber-400/40";
      } else {
        btn.className = "tab-btn flex-1 py-1.5 text-xs font-bold uppercase tracking-widest rounded-md transition-all text-amber-100/40 hover:text-amber-200";
      }
    });
    if (tab === "file") {
      panelFile?.classList.remove("hidden");
      panelCamera?.classList.add("hidden");
      stopCamera();
    } else {
      panelFile?.classList.add("hidden");
      panelCamera?.classList.remove("hidden");
    }
  }

  tabBtns?.forEach((btn) => {
    btn.addEventListener("click", () => switchPhotoTab(btn.dataset.tab));
  });

  // File input
  photoInput?.addEventListener("change", () => {
    const file = photoInput.files?.[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = (e) => {
        if (photoPreview) photoPreview.src = e.target.result;
        photoPreview?.classList.remove("hidden");
      };
      reader.readAsDataURL(file);
    }
  });

  // Drag & drop
  dropZone?.addEventListener("dragover", (e) => {
    e.preventDefault();
    dropZone.classList.add("border-amber-400/60");
  });
  dropZone?.addEventListener("dragleave", () => {
    dropZone.classList.remove("border-amber-400/60");
  });
  dropZone?.addEventListener("drop", (e) => {
    e.preventDefault();
    dropZone.classList.remove("border-amber-400/60");
    const file = e.dataTransfer?.files?.[0];
    if (file && file.type.startsWith("image/")) {
      const dataTransfer = new DataTransfer();
      dataTransfer.items.add(file);
      if (photoInput) photoInput.files = dataTransfer.files;
      photoInput?.dispatchEvent(new Event("change"));
    }
  });

  // Camera
  async function startCamera() {
    try {
      stream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: "environment", width: { ideal: 1280 }, height: { ideal: 720 } },
        audio: false,
      });
      if (video) video.srcObject = stream;
      cameraPlaceholder?.classList.add("hidden");
      startCameraBtn?.classList.add("hidden");
      captureBtn?.classList.remove("hidden");
    } catch {
      alert("No se pudo acceder a la cámara. Comprueba los permisos del navegador.");
    }
  }

  function stopCamera() {
    stream?.getTracks().forEach((t) => t.stop());
    stream = null;
    if (video) video.srcObject = null;
    startCameraBtn?.classList.remove("hidden");
    captureBtn?.classList.add("hidden");
  }

  function captureFrame() {
    if (!canvas || !video) return;
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    const ctx = canvas.getContext("2d");
    ctx?.drawImage(video, 0, 0);
    canvas.toBlob(
      (blob) => {
        if (!blob) return;
        capturedBlob = blob;
        if (capturePreview) capturePreview.src = canvas.toDataURL("image/jpeg");
        capturePreview?.classList.remove("hidden");
        video?.classList.add("hidden");
        captureBtn?.classList.add("hidden");
        retakeBtn?.classList.remove("hidden");
        stopCamera();
      },
      "image/jpeg",
      0.92
    );
  }

  startCameraBtn?.addEventListener("click", startCamera);
  captureBtn?.addEventListener("click", captureFrame);
  retakeBtn?.addEventListener("click", () => {
    capturedBlob = null;
    capturePreview?.classList.add("hidden");
    video?.classList.remove("hidden");
    retakeBtn?.classList.add("hidden");
    startCamera();
  });

  // Upload
  uploadPhotoBtn?.addEventListener("click", async () => {
    let fileToUpload = null;
    if (activeTab === "file") {
      fileToUpload = photoInput?.files?.[0];
      if (!fileToUpload) {
        alert("Primero selecciona una imagen.");
        return;
      }
    } else {
      if (!capturedBlob) {
        alert("Primero captura una foto con la cámara.");
        return;
      }
      fileToUpload = new File([capturedBlob], `captura-${Date.now()}.jpg`, { type: "image/jpeg" });
    }

    const fd = new FormData();
    fd.append("photo", fileToUpload);

    try {
      const res = await fetch("/api/chat/upload-photo", {
        method: "POST",
        body: fd,
      });
      if (res.ok) {
        const data = await res.json();
        attachmentPath = data.path;
        closePhotoModal();
        alert("Foto adjuntada. Escribe un mensaje opcional y envía.");
      } else {
        const err = await res.json();
        alert(err.error || "Error al subir la foto.");
      }
    } catch {
      alert("Error de conexión.");
    }
  });

  // ══════════════════════════════════════════════════════════════
  // Modo de entrada (normal / código)
  // ══════════════════════════════════════════════════════════════
  modeBtns?.forEach((btn) => {
    btn.addEventListener("click", () => {
      const mode = btn.dataset.mode;
      currentMode = mode;
      modeBtns.forEach((b) => {
        if (b.dataset.mode === mode) {
          b.className = "mode-btn bg-amber-400/20 border border-amber-400/40 text-amber-300 px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wide transition-all";
        } else {
          b.className = "mode-btn bg-black/40 border border-amber-400/10 text-amber-400/50 hover:text-amber-400/80 hover:border-amber-400/30 px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wide transition-all";
        }
      });
      if (mode === "code") {
        messageInput?.setAttribute("placeholder", "Escribe código...");
      } else {
        messageInput?.setAttribute("placeholder", "Escribe un mensaje... (soporta Markdown)");
      }
    });
  });

  // Scroll to bottom on load
  if (chatBox) chatBox.scrollTo(0, chatBox.scrollHeight);

  // Añadir botones de copiar a bloques de código existentes
  chatBox?.querySelectorAll('pre').forEach((pre) => {
    const code = pre.querySelector('code');
    if (code && !pre.querySelector('.copy-code-btn')) {
      // Aplicar highlight si existe
      if (hljs && !code.classList.contains('hljs')) {
        hljs.highlightElement(code);
      }
      
      const copyBtn = document.createElement('button');
      copyBtn.className = 'copy-code-btn';
      copyBtn.textContent = 'Copiar';
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(code.textContent || '');
          copyBtn.textContent = '¡Copiado!';
          copyBtn.classList.add('copied');
          setTimeout(() => {
            copyBtn.textContent = 'Copiar';
            copyBtn.classList.remove('copied');
          }, 2000);
        } catch {
          copyBtn.textContent = 'Error';
          setTimeout(() => {
            copyBtn.textContent = 'Copiar';
          }, 2000);
        }
      });
      pre.style.position = 'relative';
      pre.appendChild(copyBtn);
    }
  });

  // Exponer la función addMessageToDOM globalmente para que el script de realtime pueda usarla
  window[`addMessageToDOM_${channel}`] = addMessageToDOM;
  
  // Exponer las URLs de Supabase para el script de realtime
  if (!window.supabaseConfig) {
    window.supabaseConfig = {
      url: supabaseUrl,
      key: supabaseKey
    };
  }
</script>

<script>
  import { createClient } from "@supabase/supabase-js";

  // Este script se ejecuta después del primero, cuando window ya tiene las funciones
  setTimeout(() => {
    const chatBoxes = document.querySelectorAll("[id^='chat-box-']");
    
    chatBoxes.forEach((chatBoxEl) => {
      const channelId = chatBoxEl.id.replace("chat-box-", "");
      const addMessageFunc = (window as any)[`addMessageToDOM_${channelId}`];
      
      if (!addMessageFunc) return;

      const supabaseConfig = (window as any).supabaseConfig;
      if (!supabaseConfig) {
        console.error("Configuración de Supabase no encontrada");
        return;
      }
      
      const supabase = createClient(supabaseConfig.url, supabaseConfig.key);

      const realtimeChannel = supabase
        .channel(`messages:${channelId}`)
        .on(
          "postgres_changes",
          {
            event: "INSERT",
            schema: "public",
            table: "messages",
            filter: `channel=eq.${channelId}`,
          },
          async (payload) => {
            const { data: profile } = await supabase
              .from("profiles")
              .select("name, role, avatar_url")
              .eq("id", payload.new.user_id)
              .single();

            addMessageFunc({
              ...payload.new,
              profiles: profile || { name: "Usuario", role: null },
            });
          }
        )
        .on(
          "postgres_changes",
          {
            event: "UPDATE",
            schema: "public",
            table: "messages",
            filter: `channel=eq.${channelId}`,
          },
          async (payload) => {
            const msgDiv = chatBoxEl.querySelector(
              `[data-message-id="${payload.new.id}"]`
            ) as HTMLElement | null;
            if (!msgDiv) return;

            if (payload.new.content?.startsWith("__DELETED__:")) {
              // Mensaje borrado por su propietario → reemplazar contenido
              const deletedBy = payload.new.content.slice("__DELETED__:".length);
              const contentEl = msgDiv.querySelector(".text-amber-100\\/90");
              if (contentEl) {
                contentEl.className = "ml-10 text-amber-400/35 text-sm italic leading-relaxed select-none";
                contentEl.textContent = `🗑️ Mensaje borrado por ${deletedBy}`;
              }
              // Ocultar acciones
              msgDiv.querySelectorAll(".reply-btn, .edit-btn, .delete-btn").forEach(b => (b as HTMLElement).style.display = "none");
            } else {
              const contentEl = msgDiv.querySelector(".text-amber-100\\/90");
              if (contentEl) contentEl.textContent = payload.new.content;

              const nameRow = msgDiv.querySelector(".flex.items-center.gap-2");
              if (nameRow && !nameRow.querySelector(".edited-tag")) {
                const tag = document.createElement("span");
                tag.className = "edited-tag text-amber-400/50 text-xs italic";
                tag.textContent = "(editado)";
                nameRow.appendChild(tag);
              }

              const editBtn = msgDiv.querySelector(".edit-btn") as HTMLElement;
              if (editBtn) editBtn.dataset.content = payload.new.content;
            }
          }
        )
        .on(
          "postgres_changes",
          {
            event: "DELETE",
            schema: "public",
            table: "messages",
            filter: `channel=eq.${channelId}`,
          },
          (payload) => {
            const msgDiv = chatBoxEl.querySelector(
              `[data-message-id="${payload.old.id}"]`
            );
            if (msgDiv) msgDiv.remove();
          }
        )
        .subscribe();

      window.addEventListener("beforeunload", () => {
        supabase.removeChannel(realtimeChannel);
      });
    });
  }, 100);
</script>

